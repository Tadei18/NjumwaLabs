# Copy to .env and fill in. Never commit the real .env.

# Web3Forms access key (https://web3forms.com) — powers the contact form.
PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave blank to disable.
PUBLIC_GA4_ID=

# Plausible domain (e.g. njumwalabs.com). Leave blank to disable.
PUBLIC_PLAUSIBLE_DOMAIN=

# Calendly / Cal.com booking URL.
PUBLIC_CALENDLY_URL=https://calendly.com/crispusnjumwa

# Google Search Console verification token (content of the meta tag).
PUBLIC_GSC_VERIFICATION=

# Bing Webmaster verification token.
PUBLIC_BING_VERIFICATION=
