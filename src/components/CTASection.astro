---
import { whatsappLink } from "@data/site";
import { Icon } from "astro-icon/components";

interface Props {
  heading?: string;
  text?: string;
}

const {
  heading = "Let's build something that pays for itself.",
  text = "Book a free 20-minute call. We'll map the fastest path from where you are to a working system — no pressure, no jargon.",
} = Astro.props;
---

<section class="cta">
  <div class="container-x">
    <div class="cta-card" data-reveal>
      <span class="eyebrow cta-eyebrow">Next step</span>
      <h2 class="cta-heading">{heading}</h2>
      <p class="cta-text">{text}</p>
      <div class="cta-actions">
        <a href="/contact/" class="btn btn-primary" data-track="book_call_cta">
          <Icon name="lucide:calendar-check" />
          Book a free call
        </a>
        <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-on-dark" data-track="whatsapp_cta">
          <Icon name="lucide:message-circle" />
          Message on WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    padding-block: clamp(2.5rem, 6vw, 4.5rem);
  }
  .cta-card {
    position: relative;
    overflow: hidden;
    background: var(--color-night);
    border-radius: 28px;
    padding: clamp(2.25rem, 5vw, 4rem);
    text-align: center;
    color: #fff;
  }
  .cta-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(60% 80% at 15% 0%, color-mix(in srgb, var(--color-accent) 28%, transparent), transparent 70%),
      radial-gradient(50% 70% at 100% 100%, color-mix(in srgb, var(--color-accent-2) 18%, transparent), transparent 70%);
    pointer-events: none;
  }
  .cta-eyebrow {
    position: relative;
    color: var(--color-accent);
  }
  .cta-heading {
    position: relative;
    color: #fff;
    font-size: clamp(1.7rem, 4vw, 2.6rem);
    margin-top: 0.75rem;
    max-width: 18ch;
    margin-inline: auto;
  }
  .cta-text {
    position: relative;
    margin: 1rem auto 0;
    max-width: 48ch;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.6;
  }
  .cta-actions {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1.75rem;
  }
  .cta-actions svg {
    width: 1.15rem;
    height: 1.15rem;
  }
</style>
