---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { pillarBySlug } from "@data/services";

interface Props {
  url: string;
  title: string;
  description: string;
  client: string;
  industry: string;
  pillar: string;
  cover?: ImageMetadata;
  coverAlt?: string;
  metrics?: { value: string; label: string }[];
}
const { url, title, description, client, industry, pillar, cover, coverAlt, metrics = [] } =
  Astro.props;
const p = pillarBySlug(pillar);
---

<a href={url} class="cs-card card" data-reveal>
  <div class="cs-media">
    {cover ? (
      <Image src={cover} alt={coverAlt ?? title} width={640} height={400} class="cs-img" />
    ) : (
      <div class="cs-placeholder" aria-hidden="true">
        {p && <Icon name={`lucide:${p.icon}`} />}
      </div>
    )}
    {p && <span class="cs-tag">{p.short}</span>}
  </div>
  <div class="cs-body">
    <p class="cs-meta">{client} · {industry}</p>
    <h3 class="cs-title">{title}</h3>
    <p class="cs-desc">{description}</p>
    {metrics.length > 0 && (
      <ul class="cs-metrics">
        {metrics.slice(0, 2).map((m) => (
          <li>
            <span class="cs-metric-val">{m.value}</span>
            <span class="cs-metric-label">{m.label}</span>
          </li>
        ))}
      </ul>
    )}
    <span class="cs-cta">
      Read case study
      <Icon name="lucide:arrow-right" />
    </span>
  </div>
</a>

<style>
  .cs-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: transform 0.22s var(--ease-out), box-shadow 0.22s var(--ease-out);
  }
  .cs-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lift);
  }
  .cs-media {
    position: relative;
    aspect-ratio: 16 / 10;
    background: var(--color-surface-2);
  }
  .cs-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cs-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-night), var(--color-night-2));
    color: var(--color-accent);
  }
  .cs-placeholder svg {
    width: 3rem;
    height: 3rem;
    opacity: 0.7;
  }
  .cs-tag {
    position: absolute;
    top: 0.8rem;
    left: 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.92);
    color: var(--color-ink);
    backdrop-filter: blur(4px);
  }
  .cs-body {
    display: flex;
    flex-direction: column;
    padding: 1.4rem;
    flex-grow: 1;
  }
  .cs-meta {
    font-size: 0.82rem;
    color: var(--color-muted);
  }
  .cs-title {
    margin-top: 0.35rem;
    font-size: 1.2rem;
  }
  .cs-desc {
    margin-top: 0.5rem;
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.55;
    flex-grow: 1;
  }
  .cs-metrics {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 1.1rem 0 0;
  }
  .cs-metrics li {
    display: flex;
    flex-direction: column;
  }
  .cs-metric-val {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.3rem;
    color: var(--color-accent-ink);
  }
  .cs-metric-label {
    font-size: 0.78rem;
    color: var(--color-muted);
  }
  .cs-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.25rem;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--color-accent-ink);
  }
  .cs-cta svg {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s var(--ease-out);
  }
  .cs-card:hover .cs-cta svg {
    transform: translateX(4px);
  }
</style>
