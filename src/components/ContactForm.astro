---
import { Icon } from "astro-icon/components";
import { site } from "@data/site";
import { pillars } from "@data/services";

// Web3Forms: works without JS (standard POST + redirect). JS adds inline
// validation + async success state. Set PUBLIC_WEB3FORMS_KEY in .env.
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? "";
const budgets = ["Under $500", "$500 – $2,000", "$2,000 – $5,000", "$5,000+", "Not sure yet"];
---

<form
  class="contact-form"
  action="https://api.web3forms.com/submit"
  method="POST"
  novalidate
>
  <input type="hidden" name="access_key" value={accessKey} />
  <input type="hidden" name="subject" value="New inquiry from Njumwa Labs website" />
  <input type="hidden" name="from_name" value="Njumwa Labs website" />
  <input type="hidden" name="redirect" value={`${site.url}/contact/?sent=1`} />
  {/* Honeypot — bots fill this, humans don't. */}
  <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" />

  <div class="field-row">
    <div class="field">
      <label for="cf-name">Name</label>
      <input id="cf-name" name="name" type="text" required autocomplete="name" />
      <span class="err" data-err="name"></span>
    </div>
    <div class="field">
      <label for="cf-email">Email</label>
      <input id="cf-email" name="email" type="email" required autocomplete="email" />
      <span class="err" data-err="email"></span>
    </div>
  </div>

  <div class="field-row">
    <div class="field">
      <label for="cf-service">Service of interest</label>
      <select id="cf-service" name="service">
        <option value="">Select a service…</option>
        {pillars.map((p) => (
          <option value={p.title}>{p.title}</option>
        ))}
        <option value="Something else">Something else</option>
      </select>
    </div>
    <div class="field">
      <label for="cf-budget">Budget range</label>
      <select id="cf-budget" name="budget">
        <option value="">Select a range…</option>
        {budgets.map((b) => (
          <option value={b}>{b}</option>
        ))}
      </select>
    </div>
  </div>

  <div class="field">
    <label for="cf-message">How can I help?</label>
    <textarea id="cf-message" name="message" rows="5" required></textarea>
    <span class="err" data-err="message"></span>
  </div>

  <button type="submit" class="btn btn-primary form-submit" data-track="contact_submit">
    <Icon name="lucide:send" />
    <span class="submit-label">Send message</span>
  </button>

  <p class="form-status" role="status" aria-live="polite"></p>

  {!accessKey && (
    <p class="form-warn">
      Note: set <code>PUBLIC_WEB3FORMS_KEY</code> in your environment to enable delivery.
    </p>
  )}
</form>

<script>
  const initContactForm = () => {
  const form = document.querySelector<HTMLFormElement>(".contact-form");
  if (form) {
    const status = form.querySelector<HTMLParagraphElement>(".form-status")!;
    const submit = form.querySelector<HTMLButtonElement>(".form-submit")!;
    const label = form.querySelector<HTMLSpanElement>(".submit-label")!;

    const showErr = (name: string, msg: string) => {
      const el = form.querySelector<HTMLElement>(`[data-err="${name}"]`);
      if (el) el.textContent = msg;
    };
    const clearErrs = () =>
      form.querySelectorAll<HTMLElement>(".err").forEach((e) => (e.textContent = ""));

    const validate = () => {
      clearErrs();
      let ok = true;
      const name = form.elements.namedItem("name") as HTMLInputElement;
      const email = form.elements.namedItem("email") as HTMLInputElement;
      const message = form.elements.namedItem("message") as HTMLTextAreaElement;
      if (!name.value.trim()) (showErr("name", "Please enter your name"), (ok = false));
      if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email.value))
        (showErr("email", "Please enter a valid email"), (ok = false));
      if (message.value.trim().length < 10)
        (showErr("message", "A little more detail helps (10+ characters)"), (ok = false));
      return ok;
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      status.textContent = "";
      status.className = "form-status";
      if (!validate()) return;

      submit.disabled = true;
      label.textContent = "Sending…";

      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });
        const data = await res.json();
        if (res.ok && data.success) {
          form.reset();
          status.textContent = "Thanks! Your message is on its way — I'll reply within one business day.";
          status.classList.add("ok");
          label.textContent = "Sent";
          if ((window as any).gtag) (window as any).gtag("event", "contact_success");
        } else {
          throw new Error(data.message || "Send failed");
        }
      } catch (err) {
        status.textContent =
          "Something went wrong. Please email crispusnjumwa@gmail.com or message on WhatsApp.";
        status.classList.add("error");
        submit.disabled = false;
        label.textContent = "Send message";
      }
    });
  }
  };
  initContactForm();
  document.addEventListener("astro:page-load", initContactForm);
</script>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .hp {
    position: absolute;
    left: -9999px;
    opacity: 0;
  }
  .field-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.1rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  label {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-ink-soft);
  }
  input,
  select,
  textarea {
    width: 100%;
    font: inherit;
    font-size: 0.95rem;
    color: var(--color-ink);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 12px;
    padding: 0.75rem 0.9rem;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 22%, transparent);
  }
  textarea {
    resize: vertical;
  }
  .err {
    font-size: 0.8rem;
    color: #c0392b;
    min-height: 1em;
  }
  .form-submit {
    align-self: flex-start;
    margin-top: 0.25rem;
  }
  .form-submit svg {
    width: 1.1rem;
    height: 1.1rem;
  }
  .form-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }
  .form-status {
    font-size: 0.92rem;
    margin: 0;
  }
  .form-status.ok {
    color: var(--color-accent-ink);
    font-weight: 500;
  }
  .form-status.error {
    color: #c0392b;
  }
  .form-warn {
    font-size: 0.82rem;
    color: var(--color-muted);
  }
  .form-warn code {
    font-family: var(--font-mono);
    background: var(--color-surface-2);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }
  @media (min-width: 600px) {
    .field-row {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
