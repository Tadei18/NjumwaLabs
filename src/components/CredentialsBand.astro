---
import { Icon } from "astro-icon/components";
import { credentialGroups, verificationUrl, credentialsHeadline } from "@data/credentials";

interface Props {
  /** Dark band (home / D365) vs light (About). */
  variant?: "dark" | "light";
  heading?: string;
  eyebrow?: string;
}
const {
  variant = "dark",
  heading = credentialsHeadline,
  eyebrow = "Verified credentials",
} = Astro.props;

const groupIcon: Record<string, string> = {
  expert: "award",
  associate: "badge-check",
  ai: "brain-circuit",
};
---

<div class:list={["creds", variant]}>
  <div class="creds-head" data-reveal>
    <span class="eyebrow">{eyebrow}</span>
    <h2 class="creds-title">{heading}</h2>
  </div>

  <div class="creds-groups">
    {credentialGroups.map((g, gi) => (
      <div class="creds-group" data-reveal data-delay={String(gi + 1)}>
        <p class="creds-group-label">
          <Icon name={`lucide:${groupIcon[g.id] ?? "badge-check"}`} />
          {g.label}
          <span class="creds-count">{g.items.length}</span>
        </p>
        <ul class="creds-list">
          {g.items.map((c) => (
            <li class="creds-chip">{c.short}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  {verificationUrl && (
    <a href={verificationUrl} target="_blank" rel="noopener" class="creds-verify" data-reveal>
      Verify credentials
      <Icon name="lucide:external-link" />
    </a>
  )}
</div>

<style>
  .creds-head {
    margin-bottom: 2rem;
    max-width: 42ch;
  }
  .creds-title {
    margin-top: 0.6rem;
    font-size: clamp(1.5rem, 3.2vw, 2.25rem);
  }
  .creds-groups {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .creds-group {
    padding: 1.5rem;
    border-radius: var(--radius-card);
    border: 1px solid var(--color-line);
    background: var(--color-surface);
  }
  .creds-group-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }
  .creds-group-label svg {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--color-accent-ink);
  }
  .creds-count {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--color-accent) 14%, transparent);
    color: var(--color-accent-ink);
  }
  .creds-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .creds-chip {
    font-size: 0.82rem;
    padding: 0.4rem 0.7rem;
    border-radius: 10px;
    background: var(--color-surface-2);
    border: 1px solid var(--color-line);
    color: var(--color-ink-soft);
    line-height: 1.2;
  }
  .creds-verify {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.75rem;
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--color-accent-ink);
  }
  .creds-verify svg {
    width: 1rem;
    height: 1rem;
  }

  /* Dark variant overrides */
  .creds.dark .creds-group {
    background: rgba(255, 255, 255, 0.04);
    border-color: var(--color-night-line);
  }
  .creds.dark .creds-group-label svg {
    color: var(--color-accent);
  }
  .creds.dark .creds-count {
    color: var(--color-accent);
  }
  .creds.dark .creds-chip {
    background: rgba(255, 255, 255, 0.05);
    border-color: var(--color-night-line);
    color: rgba(255, 255, 255, 0.82);
  }
  .creds.dark .creds-verify {
    color: var(--color-accent);
  }

  @media (min-width: 800px) {
    .creds-groups {
      grid-template-columns: repeat(3, 1fr);
      align-items: start;
    }
  }
</style>
