---
import { nav, site } from "@data/site";
import { pillars } from "@data/services";
import { Icon } from "astro-icon/components";

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== "/" && path.startsWith(href));
---

<header class="site-header">
  <div class="container-x header-inner">
    <a href="/" class="brand" aria-label={`${site.name} — home`}>
      <Icon name="lucide:hexagon" class="brand-mark" />
      <span class="brand-name">Njumwa<span class="brand-accent">Labs</span></span>
    </a>

    <nav class="desktop-nav" aria-label="Primary">
      <ul>
        <li class="has-mega">
          <a href="/services/" class:list={["nav-link", { active: isActive("/services/") }]}>
            Services
            <Icon name="lucide:chevron-down" class="chev" />
          </a>
          <div class="mega" role="menu">
            <div class="mega-grid">
              {pillars.map((p) => (
                <a href={p.href} class="mega-item" role="menuitem">
                  <Icon name={`lucide:${p.icon}`} class="mega-icon" />
                  <span class="mega-title">{p.short}</span>
                  <span class="mega-desc">{p.outcome}</span>
                </a>
              ))}
              <a href="/services/" class="mega-item mega-all" role="menuitem">
                <Icon name="lucide:layout-grid" class="mega-icon" />
                <span class="mega-title">All services</span>
                <span class="mega-desc">Compare engagement types and find what you need.</span>
              </a>
            </div>
          </div>
        </li>
        {nav
          .filter((n) => n.label !== "Services")
          .map((n) => (
            <li>
              <a href={n.href} class:list={["nav-link", { active: isActive(n.href) }]}>
                {n.label}
              </a>
            </li>
          ))}
      </ul>
    </nav>

    <div class="header-cta">
      <a href="/contact/" class="btn btn-primary" data-track="book_call_header">Book a call</a>
    </div>

    <button class="menu-toggle" aria-expanded="false" aria-controls="mobile-drawer" aria-label="Open menu">
      <Icon name="lucide:menu" class="menu-icon-open" />
      <Icon name="lucide:x" class="menu-icon-close" />
    </button>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-drawer" class="drawer" hidden>
    <nav aria-label="Mobile">
      <a href="/services/" class="drawer-link">Services</a>
      <div class="drawer-sub">
        {pillars.map((p) => (
          <a href={p.href} class="drawer-sublink">{p.short}</a>
        ))}
      </div>
      {nav
        .filter((n) => n.label !== "Services")
        .map((n) => (
          <a href={n.href} class="drawer-link">{n.label}</a>
        ))}
      <a href="/contact/" class="btn btn-primary drawer-cta" data-track="book_call_mobile">Book a call</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".menu-toggle");
  const drawer = document.getElementById("mobile-drawer");
  const header = document.querySelector(".site-header");

  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!open));
    toggle.setAttribute("aria-label", open ? "Open menu" : "Close menu");
    if (drawer) drawer.hidden = open;
    document.body.style.overflow = open ? "" : "hidden";
  });

  // Shadow on scroll.
  const onScroll = () => header?.classList.toggle("scrolled", window.scrollY > 8);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: saturate(1.4) blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s, background-color 0.2s;
  }
  .site-header.scrolled {
    border-bottom-color: var(--color-line);
    background: color-mix(in srgb, var(--color-bg) 94%, transparent);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 4.25rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.15rem;
    letter-spacing: -0.02em;
  }
  .brand-mark {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--color-accent);
  }
  .brand-accent {
    color: var(--color-accent-ink);
  }

  .desktop-nav {
    display: none;
  }
  .desktop-nav ul {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.5rem 0.8rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-ink-soft);
    transition: background-color 0.15s, color 0.15s;
  }
  .nav-link:hover {
    background: var(--color-surface-2);
    color: var(--color-ink);
  }
  .nav-link.active {
    color: var(--color-accent-ink);
  }
  .chev {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s;
  }

  /* Mega menu */
  .has-mega {
    position: relative;
  }
  .mega {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    width: min(46rem, 90vw);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-lift);
    padding: 0.75rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.18s var(--ease-out), transform 0.18s var(--ease-out), visibility 0.18s;
  }
  .has-mega:hover .mega,
  .has-mega:focus-within .mega {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .has-mega:hover .chev,
  .has-mega:focus-within .chev {
    transform: rotate(180deg);
  }
  .mega-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.35rem;
  }
  .mega-item {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: 0.7rem;
    padding: 0.7rem 0.8rem;
    border-radius: 12px;
    transition: background-color 0.15s;
  }
  .mega-item:hover {
    background: var(--color-surface-2);
  }
  .mega-icon {
    grid-row: 1 / 3;
    width: 1.4rem;
    height: 1.4rem;
    color: var(--color-accent-ink);
    margin-top: 0.15rem;
  }
  .mega-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .mega-desc {
    font-size: 0.82rem;
    color: var(--color-muted);
    line-height: 1.3;
  }
  .mega-all {
    grid-column: 1 / -1;
    border-top: 1px solid var(--color-line);
    margin-top: 0.25rem;
    padding-top: 0.85rem;
  }

  .header-cta {
    display: none;
  }
  .menu-toggle {
    display: inline-flex;
    background: none;
    border: 0;
    cursor: pointer;
    color: var(--color-ink);
    padding: 0.4rem;
  }
  .menu-toggle svg {
    width: 1.6rem;
    height: 1.6rem;
  }
  .menu-icon-close {
    display: none;
  }
  .menu-toggle[aria-expanded="true"] .menu-icon-open {
    display: none;
  }
  .menu-toggle[aria-expanded="true"] .menu-icon-close {
    display: block;
  }

  .drawer {
    border-top: 1px solid var(--color-line);
    background: var(--color-surface);
    padding: 1rem 1.25rem 1.5rem;
    max-height: calc(100dvh - 4.25rem);
    overflow-y: auto;
  }
  .drawer-link {
    display: block;
    padding: 0.7rem 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.05rem;
    border-bottom: 1px solid var(--color-line);
  }
  .drawer-sub {
    display: flex;
    flex-direction: column;
    padding: 0.25rem 0 0.5rem 0.5rem;
  }
  .drawer-sublink {
    padding: 0.5rem 0;
    color: var(--color-muted);
    font-size: 0.95rem;
  }
  .drawer-cta {
    width: 100%;
    margin-top: 1.25rem;
  }

  @media (min-width: 960px) {
    .desktop-nav,
    .header-cta {
      display: flex;
    }
    .menu-toggle,
    .drawer {
      display: none;
    }
  }
</style>
