---
import { Icon } from "astro-icon/components";
import SystemsMap from "@components/SystemsMap.astro";
---

<section class="hero section-dark">
  <span class="glow glow-cyan hero-glow-1" aria-hidden="true"></span>
  <span class="glow glow-amber hero-glow-2" aria-hidden="true"></span>

  <div class="container-x hero-grid">
    <div class="hero-copy">
      <span class="eyebrow hero-eyebrow load-fade">
        <span class="pulse-dot"></span>
        Software · AI · Mobile · Data · ERP
      </span>

      <h1 class="hero-title">
        <span class="reveal-line"><span>Software, automation,</span></span>
        <span class="reveal-line"><span>and data systems that</span></span>
        <span class="reveal-line"><span class="text-gradient">grow your business.</span></span>
      </h1>

      <p class="hero-sub load-fade d2">
        I design, build, automate and maintain the systems behind growing companies — web and mobile
        apps, AI automation, reliable databases, and Dynamics 365 — at enterprise quality and
        globally affordable prices.
      </p>

      <div class="hero-actions load-fade d3">
        <a href="/contact/" class="btn btn-primary" data-track="book_call_hero">
          <Icon name="lucide:calendar-check" />
          Book a free call
        </a>
        <a href="/services/" class="btn btn-on-dark">
          See services
          <Icon name="lucide:arrow-right" />
        </a>
      </div>

      <p class="hero-creds load-fade d4">
        <Icon name="lucide:shield-check" />
        Microsoft Certified · Solution Architect Expert ×3 · 200+ user ERP go-live delivered
      </p>
    </div>

    <div class="hero-panel load-fade d2">
      <div class="panel-head">
        <span class="panel-dot"></span>
        <span class="panel-title">your business — one connected system</span>
      </div>
      <SystemsMap />
    </div>
  </div>

  <a href="#explore" class="hero-scroll load-fade d4" aria-label="Scroll to content">
    <Icon name="lucide:chevron-down" />
  </a>
</section>

<style>
  .hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding-block: clamp(3rem, 7vw, 5rem) clamp(3.5rem, 8vw, 6rem);
  }
  .hero-glow-1 {
    width: 38rem;
    height: 38rem;
    top: -12rem;
    left: -10rem;
    opacity: 0.35;
  }
  .hero-glow-2 {
    width: 32rem;
    height: 32rem;
    bottom: -14rem;
    right: -8rem;
    opacity: 0.28;
  }

  .hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
    width: 100%;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .hero-title {
    margin-top: 1.25rem;
    font-size: clamp(2.5rem, 7vw, 4.75rem);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .hero-sub {
    margin-top: 1.5rem;
    font-size: clamp(1.05rem, 2.2vw, 1.3rem);
    color: rgba(255, 255, 255, 0.74);
    line-height: 1.6;
    max-width: 46ch;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }
  .hero-actions svg {
    width: 1.15rem;
    height: 1.15rem;
  }
  .hero-creds {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.75rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.5;
  }
  .hero-creds svg {
    width: 1rem;
    height: 1rem;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .hero-panel {
    position: relative;
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01));
    border: 1px solid var(--color-night-line);
    border-radius: 24px;
    padding: 1.25rem 1.25rem 1.75rem;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
  }
  .panel-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-bottom: 0.75rem;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-night-line);
  }
  .panel-dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-accent) 25%, transparent);
  }
  .panel-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }

  .hero-scroll {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: none;
    color: rgba(255, 255, 255, 0.5);
    animation: bob 2s ease-in-out infinite;
  }
  .hero-scroll svg {
    width: 1.5rem;
    height: 1.5rem;
  }
  @keyframes bob {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(6px);
    }
  }

  @media (min-width: 980px) {
    .hero-grid {
      grid-template-columns: 1.02fr 0.98fr;
      gap: 3.5rem;
    }
    .hero-scroll {
      display: block;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-scroll {
      animation: none;
    }
  }
</style>
