---
import { Icon } from "astro-icon/components";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ServiceIllustration from "@components/ServiceIllustration.astro";
import { pillarBySlug } from "@data/services";

interface Props {
  slug: string;
  icon: string;
  eyebrow: string;
  title: string;
  subtitle: string;
  priceFrom: string;
  breadcrumbs: { name: string; url: string }[];
}
const { slug, icon, eyebrow, title, subtitle, priceFrom, breadcrumbs } = Astro.props;
const accent = pillarBySlug(slug)?.accent ?? "#0FB5C4";
---

<section class="pillar-hero bg-dots" style={`--pillar:${accent}`}>
  <span class="plh-glow" aria-hidden="true"></span>
  <div class="container-x">
    <Breadcrumbs items={breadcrumbs} />
    <div class="plh-grid">
      <div class="plh-copy">
        <span class="plh-icon load-fade">
          <Icon name={`lucide:${icon}`} />
        </span>
        <span class="eyebrow plh-eyebrow load-fade d1">{eyebrow}</span>
        <h1 class="plh-title load-fade d1">{title}</h1>
        <p class="plh-sub load-fade d2">{subtitle}</p>
        <div class="plh-actions load-fade d3">
          <a href="/contact/" class="btn btn-primary" data-track="book_call_pillar">
            <Icon name="lucide:calendar-check" />
            Book a free call
          </a>
          <a href="/pricing/" class="btn btn-ghost">
            From {priceFrom}
          </a>
        </div>
      </div>
      <div class="plh-visual load-fade d2">
        <ServiceIllustration slug={slug} />
      </div>
    </div>
  </div>
</section>

<style>
  .pillar-hero {
    position: relative;
    overflow: hidden;
    padding-block: 1.25rem clamp(2rem, 5vw, 3.25rem);
  }
  .plh-glow {
    position: absolute;
    top: -10rem;
    right: -6rem;
    width: 26rem;
    height: 26rem;
    border-radius: 50%;
    filter: blur(60px);
    background: color-mix(in srgb, var(--pillar) 45%, transparent);
    opacity: 0.16;
    pointer-events: none;
  }
  .plh-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    margin-top: 1.25rem;
  }
  .plh-icon {
    display: inline-flex;
    width: 3.25rem;
    height: 3.25rem;
    align-items: center;
    justify-content: center;
    border-radius: 16px;
    background: color-mix(in srgb, var(--pillar) 14%, var(--color-surface));
    color: color-mix(in srgb, var(--pillar) 75%, var(--color-ink));
    border: 1px solid var(--color-line);
    margin-bottom: 1.1rem;
  }
  .plh-icon svg {
    width: 1.7rem;
    height: 1.7rem;
  }
  .plh-eyebrow {
    display: block;
    color: color-mix(in srgb, var(--pillar) 70%, var(--color-ink));
  }
  .plh-title {
    margin-top: 0.6rem;
    font-size: clamp(2rem, 5vw, 3.25rem);
  }
  .plh-sub {
    margin-top: 1.1rem;
    font-size: clamp(1.05rem, 2.2vw, 1.3rem);
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 50ch;
  }
  .plh-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }
  .plh-actions svg {
    width: 1.15rem;
    height: 1.15rem;
  }
  .plh-visual {
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-lift);
    max-width: 30rem;
  }

  @media (min-width: 900px) {
    .plh-grid {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 3rem;
    }
    .plh-visual {
      justify-self: end;
    }
  }
</style>
