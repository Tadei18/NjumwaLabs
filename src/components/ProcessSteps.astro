---
import { Icon } from "astro-icon/components";

interface Step {
  title: string;
  text: string;
  icon: string;
}
interface Props {
  steps?: Step[];
}

const defaultSteps: Step[] = [
  {
    icon: "compass",
    title: "Discovery",
    text: "A free call to understand your goals, constraints and what success looks like. You leave with clarity even if we don't work together.",
  },
  {
    icon: "file-text",
    title: "Proposal",
    text: "A clear scope, timeline and fixed or milestone-based price. No surprises, no padded hours.",
  },
  {
    icon: "hammer",
    title: "Build & ship",
    text: "I build in focused iterations with regular demos, so you see progress and steer early — not at the end.",
  },
  {
    icon: "life-buoy",
    title: "Support",
    text: "Launch, monitoring and ongoing care. Systems need upkeep; I keep yours running and improving.",
  },
];

const { steps = defaultSteps } = Astro.props;
---

<ol class="steps" data-reveal>
  {steps.map((step, i) => (
    <li class="step" data-reveal data-delay={String(i + 1)}>
      <span class="step-top">
        <span class="step-icon"><Icon name={`lucide:${step.icon}`} /></span>
        <span class="step-num">{String(i + 1).padStart(2, "0")}</span>
      </span>
      <h3 class="step-title">{step.title}</h3>
      <p class="step-text">{step.text}</p>
    </li>
  ))}
</ol>

<style>
  .steps {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .step {
    position: relative;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    transition: transform 0.22s var(--ease-out), box-shadow 0.22s var(--ease-out),
      border-color 0.22s var(--ease-out);
  }
  .step:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lift);
    border-color: color-mix(in srgb, var(--color-accent) 45%, var(--color-line));
  }
  /* connecting progress line across the row (desktop), draws in on reveal */
  .steps::before {
    content: "";
    position: absolute;
    display: none;
    top: 3.1rem;
    left: 12%;
    right: 12%;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), color-mix(in srgb, var(--color-accent) 20%, transparent));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1s var(--ease-out) 0.3s;
    z-index: 0;
  }
  .steps.is-visible::before {
    transform: scaleX(1);
  }
  .step > * {
    position: relative;
    z-index: 1;
  }
  .step-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.9rem;
  }
  .step-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 12px;
    background: color-mix(in srgb, var(--color-accent) 12%, var(--color-surface));
    color: var(--color-accent-ink);
    box-shadow: 0 0 0 5px var(--color-surface);
  }
  .step-icon svg {
    width: 1.35rem;
    height: 1.35rem;
  }
  .step-num {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent-ink);
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
  }
  .step-title {
    margin-top: 0.9rem;
    font-size: 1.15rem;
  }
  .step-text {
    margin-top: 0.45rem;
    color: var(--color-muted);
    line-height: 1.55;
    font-size: 0.95rem;
  }
  @media (min-width: 640px) {
    .steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .steps {
      grid-template-columns: repeat(4, 1fr);
    }
    .steps::before {
      display: block;
    }
  }
</style>
