---
// Styled wrapper for MDX content (blog + case studies).
---

<div class="prose">
  <slot />
</div>

<style is:global>
  .prose {
    max-width: 68ch;
    color: var(--color-ink-soft);
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .prose > * + * {
    margin-top: 1.15rem;
  }
  .prose h2 {
    font-size: 1.6rem;
    margin-top: 2.5rem;
    scroll-margin-top: 6rem;
  }
  .prose h3 {
    font-size: 1.25rem;
    margin-top: 2rem;
    scroll-margin-top: 6rem;
  }
  .prose h2 + p,
  .prose h3 + p {
    margin-top: 0.75rem;
  }
  .prose a {
    color: var(--color-accent-ink);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose strong {
    color: var(--color-ink);
    font-weight: 650;
  }
  .prose ul,
  .prose ol {
    padding-left: 1.4rem;
  }
  .prose li + li {
    margin-top: 0.4rem;
  }
  .prose blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.1rem;
    color: var(--color-muted);
    font-style: italic;
  }
  .prose code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--color-surface-2);
    padding: 0.15em 0.4em;
    border-radius: 5px;
  }
  .prose pre {
    background: var(--color-night);
    color: #e6edf3;
    padding: 1.1rem 1.25rem;
    border-radius: 12px;
    overflow-x: auto;
    font-size: 0.9rem;
  }
  .prose pre code {
    background: none;
    padding: 0;
  }
  .prose img {
    border-radius: 12px;
    border: 1px solid var(--color-line);
  }
  .prose hr {
    border: none;
    border-top: 1px solid var(--color-line);
    margin-block: 2rem;
  }
  .prose table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .prose th,
  .prose td {
    border: 1px solid var(--color-line);
    padding: 0.6rem 0.8rem;
    text-align: left;
  }
  .prose th {
    background: var(--color-surface-2);
    font-family: var(--font-display);
  }
</style>
