---
import { Icon } from "astro-icon/components";

// Internal-linking block — surfaces related services, posts, comparisons,
// cost guides and glossary terms. Strengthens topical clustering for SEO/GEO.
export interface RelatedLink {
  label: string;
  href: string;
  kind?: "service" | "post" | "compare" | "cost" | "glossary" | "tool";
}
interface Props {
  title?: string;
  links: RelatedLink[];
}
const { title = "Related", links } = Astro.props;
const icons: Record<string, string> = {
  service: "layers",
  post: "file-text",
  compare: "git-compare",
  cost: "calculator",
  glossary: "book-open",
  tool: "wrench",
};
---

{links.length > 0 && (
  <nav class="related" aria-label={title}>
    <p class="related-title">{title}</p>
    <ul>
      {links.map((l) => (
        <li>
          <a href={l.href}>
            <Icon name={`lucide:${icons[l.kind ?? "post"] ?? "arrow-right"}`} />
            <span>{l.label}</span>
            <Icon name="lucide:arrow-up-right" class="r-arrow" />
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .related {
    margin: 2rem 0;
    padding: 1.4rem 1.6rem;
    background: var(--color-surface-2);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
  }
  .related-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin: 0 0 0.85rem;
  }
  .related ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .related a {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 0.5rem;
    border-radius: 10px;
    font-weight: 500;
    transition: background-color 0.15s;
  }
  .related a:hover {
    background: var(--color-surface);
  }
  .related a > svg:first-child {
    width: 1.1rem;
    height: 1.1rem;
    color: var(--color-accent-ink);
    flex-shrink: 0;
  }
  .related a span {
    flex-grow: 1;
  }
  .r-arrow {
    width: 0.95rem;
    height: 0.95rem;
    color: var(--color-muted);
  }
</style>
