---
import { Icon } from "astro-icon/components";
import ServiceIllustration from "@components/ServiceIllustration.astro";
import type { Pillar } from "@data/services";

interface Props {
  pillar: Pillar;
  index?: number;
}
const { pillar, index } = Astro.props;
---

<a href={pillar.href} class="service-card" data-reveal style={`--pillar:${pillar.accent}`}>
  <div class="card-illus">
    <ServiceIllustration slug={pillar.slug} />
    {index !== undefined && <span class="card-num">{String(index + 1).padStart(2, "0")}</span>}
  </div>
  <div class="card-body">
    <h3 class="card-title">{pillar.title}</h3>
    <p class="card-outcome">{pillar.outcome}</p>
    <span class="card-cta">
      Explore
      <Icon name="lucide:arrow-right" />
    </span>
  </div>
</a>

<style>
  .service-card {
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    transition:
      transform 0.22s var(--ease-out),
      box-shadow 0.22s var(--ease-out),
      border-color 0.22s var(--ease-out);
  }
  .service-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: var(--radius-card);
    background: radial-gradient(
      120% 80% at 50% 0%,
      color-mix(in srgb, var(--pillar) 9%, transparent),
      transparent 55%
    );
    opacity: 0;
    transition: opacity 0.25s var(--ease-out);
    pointer-events: none;
  }
  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lift);
    border-color: color-mix(in srgb, var(--pillar) 55%, var(--color-line));
  }
  .service-card:hover::after {
    opacity: 1;
  }

  .card-illus {
    position: relative;
    padding: 0.6rem 0.6rem 0;
  }
  .card-num {
    position: absolute;
    top: 1.1rem;
    right: 1.2rem;
    z-index: 2;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.82rem;
    color: var(--pillar);
    background: rgba(10, 19, 34, 0.55);
    padding: 0.15rem 0.45rem;
    border-radius: 6px;
    backdrop-filter: blur(2px);
  }

  .card-body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    padding: 1.3rem 1.5rem 1.5rem;
  }
  .card-title {
    font-size: 1.2rem;
  }
  .card-outcome {
    margin-top: 0.5rem;
    color: var(--color-muted);
    line-height: 1.55;
    flex-grow: 1;
  }
  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.25rem;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.9rem;
    color: color-mix(in srgb, var(--pillar) 75%, var(--color-ink));
  }
  .card-cta svg {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s var(--ease-out);
  }
  .service-card:hover .card-cta svg {
    transform: translateX(4px);
  }
</style>
