---
// A figure with an inline source attribution — builds the sourced, citable feel
// AI engines favour. Usable in .astro and MDX.
interface Props {
  value: string;
  label: string;
  source?: string;
  sourceUrl?: string;
}
const { value, label, source, sourceUrl } = Astro.props;
---

<div class="stat-callout">
  <span class="sc-value">{value}</span>
  <span class="sc-label">{label}</span>
  {source && (
    <span class="sc-source">
      Source:
      {sourceUrl ? (
        <a href={sourceUrl} target="_blank" rel="noopener">{source}</a>
      ) : (
        <span>{source}</span>
      )}
    </span>
  )}
</div>

<style>
  .stat-callout {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--color-accent);
    border-radius: 12px;
  }
  .sc-value {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    line-height: 1;
    color: var(--color-accent-ink);
  }
  .sc-label {
    margin-top: 0.3rem;
    color: var(--color-ink-soft);
    line-height: 1.4;
  }
  .sc-source {
    margin-top: 0.5rem;
    font-size: 0.78rem;
    color: var(--color-muted);
  }
  .sc-source a {
    color: var(--color-accent-ink);
    text-decoration: underline;
  }
</style>
