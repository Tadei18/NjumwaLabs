---
// Signature element: an animated node-graph showing the five service pillars
// wired into one business "operating system". On load: nodes scale in and lines
// draw; after load: lines carry a travelling pulse and nodes breathe. Hovering a
// node highlights its links and previews how it feeds the others. Pure SVG + JS.
import { pillars } from "@data/services";

// Pentagon layout around a centre hub (viewBox 600 x 520).
const C = { x: 300, y: 260 };
const positions = [
  { x: 300, y: 78 }, // web (top)
  { x: 520, y: 210 }, // ai (upper right)
  { x: 438, y: 460 }, // mobile (lower right)
  { x: 162, y: 460 }, // data (lower left)
  { x: 80, y: 210 }, // erp (upper left)
];

const nodes = pillars.map((p, i) => ({ ...p, ...positions[i], id: p.slug }));

const feeds: Record<string, string> = {
  "web-development":
    "The front door. Your site captures demand, then hands leads to AI automation and data to act on.",
  "ai-automation":
    "The nervous system. It connects your web, mobile, data and ERP so work flows without manual handoffs.",
  "mobile-apps":
    "The pocket channel. Apps push the same data and automations into your customers' and team's hands.",
  "database-administration":
    "The foundation. Clean, fast, reliable data makes every other layer trustworthy and quick.",
  "dynamics-365-finance-operations":
    "The back office. ERP keeps finance and operations in sync, fed by automation and clean data.",
};

const ring = [
  [0, 1],
  [1, 2],
  [2, 3],
  [3, 4],
  [4, 0],
];
---

<figure class="systems-map" aria-labelledby="sysmap-caption">
  <svg
    viewBox="0 0 600 520"
    role="img"
    aria-label="Interactive map of five connected services — web development, AI automation, mobile apps, database administration and Dynamics 365 — all feeding one business operating system."
    class="sysmap-svg"
  >
    <defs>
      <radialGradient id="hubGrad" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#0fb5c4" stop-opacity="0.45" />
        <stop offset="100%" stop-color="#0fb5c4" stop-opacity="0" />
      </radialGradient>
      <linearGradient id="nodeGrad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#16223e" />
        <stop offset="100%" stop-color="#0d1428" />
      </linearGradient>
    </defs>

    {/* base edges (draw in on load) */}
    <g class="edges" fill="none" stroke-linecap="round">
      {nodes.map((n, i) => (
        <line
          class="edge spoke"
          data-from={n.id}
          style={`--i:${i}`}
          pathLength="1"
          x1={C.x}
          y1={C.y}
          x2={n.x}
          y2={n.y}
        />
      ))}
      {ring.map(([a, b], i) => (
        <line
          class="edge ring"
          data-a={nodes[a].id}
          data-b={nodes[b].id}
          style={`--i:${i + 5}`}
          pathLength="1"
          x1={nodes[a].x}
          y1={nodes[a].y}
          x2={nodes[b].x}
          y2={nodes[b].y}
        />
      ))}
    </g>

    {/* travelling pulses along the spokes */}
    <g class="pulses" fill="none" stroke-linecap="round" aria-hidden="true">
      {nodes.map((n, i) => (
        <line
          class="pulse"
          data-from={n.id}
          style={`--i:${i}`}
          pathLength="1"
          x1={C.x}
          y1={C.y}
          x2={n.x}
          y2={n.y}
        />
      ))}
    </g>

    {/* hub */}
    <circle cx={C.x} cy={C.y} r="86" fill="url(#hubGrad)" class="hub-glow" />
    <g class="hub">
      <circle cx={C.x} cy={C.y} r="50" class="hub-core" />
      <text x={C.x} y={C.y - 5} text-anchor="middle" class="hub-label hub-label-sm">YOUR</text>
      <text x={C.x} y={C.y + 13} text-anchor="middle" class="hub-label">business OS</text>
    </g>

    {/* nodes */}
    {nodes.map((n, i) => (
      <a href={n.href} class="node" data-node={n.id} style={`--i:${i}`} aria-label={`${n.title} — view services`}>
        <circle cx={n.x} cy={n.y} r="40" class="node-halo" />
        <circle cx={n.x} cy={n.y} r="36" class="node-circle" />
        <text x={n.x} y={n.y + 4} text-anchor="middle" class="node-label">
          {n.short.split(" ")[0]}
        </text>
      </a>
    ))}
  </svg>

  <figcaption
    id="sysmap-caption"
    class="sysmap-caption"
    data-default="Five capabilities, one connected system. Hover a node to see how it feeds the others."
  >
    Five capabilities, one connected system. Hover a node to see how it feeds the others.
  </figcaption>
</figure>

<script is:inline define:vars={{ feeds }}>
  (() => {
    const map = document.querySelector(".systems-map");
    if (!map) return;
    const svg = map.querySelector("svg");
    const caption = map.querySelector(".sysmap-caption");
    const def = caption.getAttribute("data-default");

    const setActive = (id) => {
      svg.querySelectorAll(".edge").forEach((e) => {
        const on = e.dataset.from === id || e.dataset.a === id || e.dataset.b === id;
        e.classList.toggle("active", !!id && on);
      });
      svg.querySelectorAll(".node").forEach((n) => {
        n.classList.toggle("dim", !!id && n.dataset.node !== id);
      });
      caption.textContent = id ? feeds[id] : def;
    };

    svg.querySelectorAll(".node").forEach((node) => {
      const id = node.dataset.node;
      node.addEventListener("mouseenter", () => setActive(id));
      node.addEventListener("focus", () => setActive(id));
      node.addEventListener("mouseleave", () => setActive(null));
      node.addEventListener("blur", () => setActive(null));
    });
  })();
</script>

<style>
  .systems-map {
    margin: 0;
    width: 100%;
  }
  .sysmap-svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  /* ---- draw-in on load ---- */
  .edge {
    stroke: rgba(255, 255, 255, 0.14);
    stroke-width: 1.5;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: draw 0.9s var(--ease-out) forwards;
    animation-delay: calc(0.25s + var(--i) * 0.08s);
  }
  .ring {
    stroke-dasharray: 0.02 0.04;
    stroke-dashoffset: 0;
    opacity: 0.5;
    animation: ring-in 0.6s var(--ease-out) forwards;
    animation-delay: calc(0.9s + var(--i) * 0.05s);
  }
  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }
  @keyframes ring-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 0.5;
    }
  }
  .edge.active {
    stroke: var(--color-accent);
    stroke-width: 2.5;
    opacity: 1;
  }

  /* ---- travelling pulses ---- */
  .pulse {
    stroke: var(--color-accent);
    stroke-width: 2.5;
    stroke-dasharray: 0.12 0.88;
    stroke-dashoffset: 1;
    opacity: 0;
    animation: travel 3.2s linear infinite;
    animation-delay: calc(1.4s + var(--i) * 0.5s);
  }
  @keyframes travel {
    0% {
      stroke-dashoffset: 1;
      opacity: 0;
    }
    15% {
      opacity: 0.9;
    }
    85% {
      opacity: 0.9;
    }
    100% {
      stroke-dashoffset: 0;
      opacity: 0;
    }
  }

  /* ---- hub ---- */
  .hub-core {
    fill: #0c1426;
    stroke: var(--color-accent);
    stroke-width: 1.5;
  }
  .hub-label {
    fill: #fff;
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
  }
  .hub-label-sm {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.2em;
    fill: var(--color-accent);
  }
  .hub-glow {
    transform-box: fill-box;
    transform-origin: center;
    animation: breathe 4s var(--ease-out) infinite;
  }

  /* ---- nodes ---- */
  .node {
    cursor: pointer;
    opacity: 0;
    transform: scale(0.6);
    transform-box: fill-box;
    transform-origin: center;
    animation: pop 0.6s var(--ease-out) forwards;
    animation-delay: calc(0.4s + var(--i) * 0.1s);
    transition: opacity 0.25s var(--ease-out);
  }
  @keyframes pop {
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
  .node.dim {
    opacity: 0.35;
  }
  .node-halo {
    fill: var(--color-accent);
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    animation: halo 4s var(--ease-out) infinite;
    animation-delay: calc(var(--i) * 0.4s);
  }
  @keyframes halo {
    0%,
    100% {
      opacity: 0;
      transform: scale(0.85);
    }
    50% {
      opacity: 0.12;
      transform: scale(1.1);
    }
  }
  @keyframes breathe {
    0%,
    100% {
      opacity: 0.7;
      transform: scale(0.95);
    }
    50% {
      opacity: 1;
      transform: scale(1.06);
    }
  }
  .node-circle {
    fill: url(#nodeGrad);
    stroke: rgba(255, 255, 255, 0.16);
    stroke-width: 1.5;
    transition: stroke 0.2s var(--ease-out), filter 0.2s var(--ease-out);
  }
  .node:hover .node-circle,
  .node:focus-visible .node-circle {
    stroke: var(--color-accent);
    filter: drop-shadow(0 0 10px color-mix(in srgb, var(--color-accent) 60%, transparent));
  }
  .node:hover .node-halo,
  .node:focus-visible .node-halo {
    opacity: 0.2;
  }
  .node-label {
    fill: #dbe4f5;
    font-family: var(--font-mono);
    font-size: 12.5px;
    font-weight: 500;
    pointer-events: none;
  }
  .node:focus {
    outline: none;
  }

  .sysmap-caption {
    margin-top: 1.25rem;
    text-align: center;
    min-height: 3em;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.95rem;
    line-height: 1.5;
    max-width: 46ch;
    margin-inline: auto;
    transition: opacity 0.2s var(--ease-out);
  }

  @media (prefers-reduced-motion: reduce) {
    .edge {
      stroke-dashoffset: 0;
      animation: none;
    }
    .ring {
      opacity: 0.5;
      animation: none;
    }
    .pulse {
      display: none;
    }
    .node {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .node-halo,
    .hub-glow {
      animation: none;
    }
    .hub-glow {
      opacity: 0.8;
    }
  }
</style>
