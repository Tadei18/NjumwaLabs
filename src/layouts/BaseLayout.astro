---
import "../styles/global.css";
import Seo from "@components/Seo.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Analytics from "@components/Analytics.astro";
import { organizationSchema, websiteSchema } from "@/lib/schema";

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: "website" | "article";
  canonical?: string;
  noindex?: boolean;
  schemas?: Record<string, unknown>[];
  publishedTime?: string;
  modifiedTime?: string;
  /** Set true on home only to add Organization + WebSite global schema. */
  isHome?: boolean;
}

const {
  title,
  description,
  image,
  type,
  canonical,
  noindex,
  schemas = [],
  publishedTime,
  modifiedTime,
  isHome = false,
} = Astro.props;

const globalSchemas = isHome ? [organizationSchema(), websiteSchema()] : [];
const allSchemas = [...globalSchemas, ...schemas];

const gscToken = import.meta.env.PUBLIC_GSC_VERIFICATION;
const bingToken = import.meta.env.PUBLIC_BING_VERIFICATION;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#10182b" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {gscToken && <meta name="google-site-verification" content={gscToken} />}
    {bingToken && <meta name="msvalidate.01" content={bingToken} />}

    <Seo
      title={title}
      description={description}
      image={image}
      type={type}
      canonical={canonical}
      noindex={noindex}
      schemas={allSchemas}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
    />

    <Analytics />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll-reveal — minimal, respects reduced-motion via CSS.
      const reveal = () => {
        const els = document.querySelectorAll("[data-reveal]");
        if (!("IntersectionObserver" in window) || els.length === 0) {
          els.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
      };
      reveal();
      document.addEventListener("astro:page-load", reveal);
    </script>

    <style>
      .skip-link {
        position: absolute;
        left: 1rem;
        top: -3rem;
        z-index: 100;
        background: var(--color-ink);
        color: #fff;
        padding: 0.6rem 1rem;
        border-radius: 8px;
        transition: top 0.2s ease;
      }
      .skip-link:focus {
        top: 1rem;
      }
    </style>
  </body>
</html>
