---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { pillars } from "@data/services";

const quick = [
  { label: "Home", href: "/" },
  { label: "Services", href: "/services/" },
  { label: "Portfolio", href: "/portfolio/" },
  { label: "Pricing", href: "/pricing/" },
  { label: "Blog", href: "/blog/" },
  { label: "Contact", href: "/contact/" },
];
---

<BaseLayout title="Page not found" description="That page doesn't exist — here's how to find what you need." noindex={true}>
  <section class="nf">
    <div class="container-x">
      <span class="nf-code">404</span>
      <h1 class="nf-title">This page took the day off.</h1>
      <p class="nf-text">
        The page you're after doesn't exist or has moved. Let's get you somewhere useful.
      </p>
      <div class="nf-actions">
        <a href="/" class="btn btn-primary"><Icon name="lucide:home" /> Back home</a>
        <a href="/contact/" class="btn btn-ghost">Get in touch</a>
      </div>

      <nav class="nf-quick" aria-label="Quick links">
        {quick.map((q) => (
          <a href={q.href} class="nf-chip">{q.label}</a>
        ))}
      </nav>

      <div class="nf-services">
        <p class="nf-services-label">Looking for a service?</p>
        <ul>
          {pillars.map((p) => (
            <li><a href={p.href} class="link-underline">{p.short}</a></li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    text-align: center;
    padding-block: clamp(3rem, 10vw, 7rem);
  }
  .nf-code {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: clamp(3rem, 12vw, 6rem);
    color: var(--color-accent);
    line-height: 1;
  }
  .nf-title {
    margin-top: 0.5rem;
    font-size: clamp(1.8rem, 5vw, 2.75rem);
  }
  .nf-text {
    margin: 1rem auto 0;
    max-width: 42ch;
    color: var(--color-muted);
    line-height: 1.6;
  }
  .nf-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1.75rem;
  }
  .nf-actions svg {
    width: 1.1rem;
    height: 1.1rem;
  }
  .nf-quick {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-top: 2.5rem;
  }
  .nf-chip {
    padding: 0.45rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
    font-size: 0.88rem;
  }
  .nf-chip:hover {
    border-color: var(--color-accent);
  }
  .nf-services {
    margin-top: 2.5rem;
  }
  .nf-services-label {
    font-size: 0.85rem;
    color: var(--color-muted);
  }
  .nf-services ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
    font-size: 0.9rem;
  }
</style>
