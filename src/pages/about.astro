---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ProcessSteps from "@components/ProcessSteps.astro";
import CTASection from "@components/CTASection.astro";
import CredentialsBand from "@components/CredentialsBand.astro";
import { Icon } from "astro-icon/components";
import { site } from "@data/site";
import { verificationUrl } from "@data/credentials";
import { personSchema, organizationSchema, breadcrumbSchema } from "@/lib/schema";

const credLink = verificationUrl;

const values = [
  { icon: "shield-check", title: "Reliability", text: "I do what I say, on the timeline I promise. Production systems have to be dependable — and so does the person building them." },
  { icon: "message-square-text", title: "Clear communication", text: "No jargon walls, no silence. You get plain-language updates and regular demos so you always know where things stand." },
  { icon: "globe-2", title: "Global standards, fair prices", text: "Enterprise-grade engineering shouldn't be out of reach. I deliver international quality at prices SMEs and startups can actually afford." },
  { icon: "target", title: "Outcomes over output", text: "I care about what the work does for your business — more leads, less manual effort, faster systems — not just shipping features." },
];

const expertise = [
  {
    icon: "building-2",
    title: "Dynamics 365 Finance & Operations",
    tags: ["X++", "Chain of Command", "DMF", "SSRS", "Power BI", "Azure DevOps"],
  },
  {
    icon: "code-2",
    title: "Full-stack web development",
    tags: ["React", "Next.js", "Astro", "Node.js", "Python"],
  },
  {
    icon: "bot",
    title: "AI automation & agents",
    tags: ["OpenAI", "RAG", "n8n", "LangChain", "WhatsApp API"],
  },
  {
    icon: "smartphone",
    title: "Cross-platform mobile",
    tags: ["Flutter", "React Native", "Supabase", "M-Pesa"],
  },
  {
    icon: "database",
    title: "Database administration & data",
    tags: ["PostgreSQL", "SQL Server", "MongoDB", "Power BI"],
  },
  {
    icon: "cloud",
    title: "Cloud & Power Platform",
    tags: ["Azure", "Power Apps", "Power Automate", "Dataverse", "Fabric"],
  },
];

const stack = [
  "TypeScript", "React", "Next.js", "Astro", "Node.js", "Python", "Flutter",
  "PostgreSQL", "SQL Server", "MongoDB", "Azure", "AWS", "Dynamics 365 F&O",
  "X++", "Power Platform", "n8n", "OpenAI", "Power BI",
];
---

<BaseLayout
  title="About Crispus Njumwa — software engineer & D365 F&O consultant"
  description="Crispus Martin Njumwa is a Microsoft-certified Dynamics 365 Finance & Operations technical consultant in Nairobi — Solution Architect Expert (×3), proven on a 200+ user enterprise ERP go-live — building software, AI, mobile and data systems for clients worldwide."
  schemas={[
    personSchema(),
    organizationSchema(),
    breadcrumbSchema([{ name: "Home", url: "/" }, { name: "About", url: "/about/" }]),
  ]}
>
  <section class="about-hero">
    <div class="container-x">
      <Breadcrumbs items={[{ name: "About", url: "/about/" }]} />
      <div class="about-grid">
        <div data-reveal>
          <span class="eyebrow">About</span>
          <h1 class="about-title">Hi, I'm Crispus — the engineer behind Njumwa Labs.</h1>
          <p class="about-lead">
            I'm a Microsoft-certified Dynamics 365 Finance & Operations technical consultant in
            {site.city}, holding three Microsoft Solution Architect Expert certifications — across
            D365 F&O, Azure and the Power Platform.
          </p>
          <p class="about-body">
            After a BSc in Computer Science at Egerton University, I joined Impax Business Solutions
            as a D365 F&O developer, where I delivered technical components on an enterprise insurance
            ERP go-live serving 200+ users across General Ledger, AR, AP, Fixed Assets, Inventory and
            Procurement. That's where I learned to build things that have to be reliable, secure and
            upgrade-safe under real production load.
          </p>
          <p class="about-body">
            Njumwa Labs is how I bring that same enterprise standard to SMEs, startups and founders —
            in {site.city} and around the world — without the enterprise price tag. Whether it's a
            fast website, an AI automation that answers leads in seconds, a mobile app, a database
            that finally runs quickly, or deep D365 work, I'm the technical partner who can build it,
            automate it, and keep it running.
          </p>
          <div class="about-actions">
            <a href="/contact/" class="btn btn-primary" data-track="book_call_about">
              <Icon name="lucide:calendar-check" /> Book a free call
            </a>
            <a href={site.socials.linkedin} target="_blank" rel="noopener" class="btn btn-ghost">
              <Icon name="lucide:linkedin" /> Connect on LinkedIn
            </a>
          </div>
        </div>
        <aside class="about-card card-gradient" data-reveal>
          <div class="ac-avatar">
            <span class="ac-monogram" aria-hidden="true">CN</span>
            {/* Drop a real photo at /public/images/crispus-njumwa.jpg — it covers
                the monogram automatically; on 404 the img removes itself. */}
            <img
              class="ac-photo"
              src="/images/crispus-njumwa.jpg"
              alt={site.founder}
              loading="lazy"
              width="120"
              height="120"
              onerror="this.remove()"
            />
          </div>
          <p class="ac-name">{site.founder}</p>
          <p class="ac-role">Microsoft-certified D365 F&O technical consultant</p>
          <ul class="ac-meta">
            <li><Icon name="lucide:map-pin" /> {site.city}</li>
            <li><Icon name="lucide:globe" /> Serving clients worldwide</li>
            <li><Icon name="lucide:clock" /> Time-zone friendly delivery</li>
          </ul>
          {credLink && (
            <a href={credLink} target="_blank" rel="noopener" class="ac-verify">
              <Icon name="lucide:badge-check" /> Verify credentials
            </a>
          )}
        </aside>
      </div>
    </div>
  </section>

  <!-- Expertise -->
  <section class="section">
    <div class="container-x">
      <SectionHeading
        eyebrow="Experience & expertise"
        title="Microsoft-certified, multidisciplinary, hands-on."
        text="The range isn't a gimmick — modern businesses run on connected systems, and I've worked across the whole stack that powers them."
      />
      <ul class="expertise">
        {expertise.map((e, i) => (
          <li class="exp-item card-hover" data-reveal data-delay={String((i % 3) + 1)}>
            <span class="exp-icon"><Icon name={`lucide:${e.icon}`} /></span>
            <div class="exp-body">
              <h3 class="exp-title">{e.title}</h3>
              <ul class="exp-tags">
                {e.tags.map((t) => (
                  <li class="exp-tag">{t}</li>
                ))}
              </ul>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Credentials -->
  <section class="section creds-section">
    <div class="container-x">
      <CredentialsBand variant="light" eyebrow="Certifications & credentials" />
    </div>
  </section>

  <!-- Values -->
  <section class="section values">
    <div class="container-x">
      <SectionHeading eyebrow="How I work" title="What you can count on." />
      <div class="values-grid">
        {values.map((v) => (
          <div class="value card" data-reveal>
            <span class="value-icon"><Icon name={`lucide:${v.icon}`} /></span>
            <h3 class="value-title">{v.title}</h3>
            <p class="value-text">{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stack -->
  <section class="section">
    <div class="container-x">
      <SectionHeading eyebrow="My stack" title="Tools I reach for" align="center" />
      <ul class="stack" data-reveal>
        {stack.map((s) => <li class="stack-item">{s}</li>)}
      </ul>
    </div>
  </section>

  <!-- Process -->
  <section class="section process">
    <div class="container-x">
      <SectionHeading eyebrow="The process" title="How an engagement runs" />
      <ProcessSteps />
    </div>
  </section>

  <CTASection heading="Let's talk about what you're building." />
</BaseLayout>

<style>
  .about-hero {
    position: relative;
    overflow: hidden;
    padding-block: 1.5rem clamp(2.5rem, 6vw, 4rem);
  }
  .about-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(40% 55% at 90% 0%, color-mix(in srgb, var(--color-accent) 12%, transparent), transparent 70%);
    pointer-events: none;
  }
  .about-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-top: 1.5rem;
    align-items: start;
  }
  .about-title {
    margin-top: 0.6rem;
    font-size: clamp(1.9rem, 4.5vw, 3rem);
  }
  .about-lead {
    margin-top: 1.1rem;
    font-size: 1.15rem;
    color: var(--color-ink-soft);
    line-height: 1.6;
  }
  .about-body {
    margin-top: 1rem;
    color: var(--color-muted);
    line-height: 1.65;
  }
  .about-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }
  .about-actions svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .about-card {
    padding: 2rem 1.75rem;
    text-align: center;
  }
  .ac-avatar {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 6rem;
    height: 6rem;
    border-radius: 50%;
    margin-bottom: 1.1rem;
    overflow: hidden;
    background: #0a1322;
    /* cyan→amber gradient ring */
    box-shadow:
      0 0 0 2px #0a1322,
      0 0 0 4px transparent;
    background-image: linear-gradient(#0a1322, #0a1322),
      linear-gradient(140deg, var(--color-accent), var(--color-accent-2));
    background-origin: border-box;
    background-clip: content-box, border-box;
    border: 3px solid transparent;
  }
  .ac-monogram {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.9rem;
    color: var(--color-accent);
  }
  .ac-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }
  .ac-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.3rem;
    color: #fff;
  }
  .ac-role {
    margin-top: 0.3rem;
    font-size: 0.9rem;
    color: var(--color-accent);
  }
  .ac-meta {
    list-style: none;
    padding: 1.25rem 0 0;
    margin: 1.25rem 0 0;
    border-top: 1px solid var(--color-night-line);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    text-align: left;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.82);
  }
  .ac-meta li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }
  .ac-meta svg {
    width: 1.05rem;
    height: 1.05rem;
    color: var(--color-accent);
  }
  .ac-verify {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.25rem;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--color-accent);
  }
  .ac-verify svg {
    width: 1.05rem;
    height: 1.05rem;
  }

  .expertise {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .exp-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.8rem;
    height: 2.8rem;
    flex-shrink: 0;
    border-radius: 12px;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent-ink);
  }
  .exp-icon svg {
    width: 1.4rem;
    height: 1.4rem;
  }
  .exp-title {
    font-size: 1.02rem;
  }
  .exp-tags {
    list-style: none;
    padding: 0;
    margin: 0.6rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .exp-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-pill);
    background: var(--color-surface-2);
    border: 1px solid var(--color-line);
    color: var(--color-ink-soft);
  }
  .exp-item {
    display: flex;
    gap: 0.9rem;
    align-items: flex-start;
    padding: 1.3rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
  }

  .values {
    background: var(--color-surface-2);
  }
  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .value {
    padding: 1.6rem;
  }
  .value-icon {
    display: inline-flex;
    width: 2.8rem;
    height: 2.8rem;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent-ink);
    margin-bottom: 0.9rem;
  }
  .value-icon svg {
    width: 1.4rem;
    height: 1.4rem;
  }
  .value-title {
    font-size: 1.1rem;
  }
  .value-text {
    margin-top: 0.45rem;
    color: var(--color-muted);
    font-size: 0.94rem;
    line-height: 1.55;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .stack-item {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.5rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
  }

  .process {
    background: var(--color-surface-2);
  }

  @media (min-width: 720px) {
    .values-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 960px) {
    .about-grid {
      grid-template-columns: 1.6fr 1fr;
    }
    .expertise {
      grid-template-columns: repeat(2, 1fr);
    }
    .values-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
