---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import Prose from "@components/Prose.astro";
import CTASection from "@components/CTASection.astro";
import BlogCover from "@components/BlogCover.astro";
import { Icon } from "astro-icon/components";
import { site } from "@data/site";
import { categoryLabel } from "@/lib/categories";
import { pillarBySlug } from "@data/services";
import { readingTime } from "@/lib/reading";
import { blogPostingSchema, breadcrumbSchema } from "@/lib/schema";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { data } = post;
const { Content, headings } = await render(post);

// Related: same category, then most recent.
const all = (await getCollection("blog", ({ data }) => !data.draft)).filter((p) => p.id !== post.id);
const related = [
  ...all.filter((p) => p.data.category === data.category),
  ...all.filter((p) => p.data.category !== data.category),
].slice(0, 3);

const pillar = data.category !== "general" ? pillarBySlug(data.category) : undefined;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const accent = data.category === "general" ? "#0FB5C4" : (pillar?.accent ?? "#0FB5C4");

const minutes = readingTime(post.body);
const words = (post.body ?? "").split(/\s+/).filter(Boolean).length;

const url = `/blog/${post.id}/`;
const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const schemas = [
  blogPostingSchema({
    title: data.title,
    description: data.description,
    url,
    datePublished: data.pubDate.toISOString(),
    dateModified: data.updatedDate?.toISOString(),
    image: data.cover?.src,
    author: data.author,
    wordCount: words,
    readingMinutes: minutes,
  }),
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Blog", url: "/blog/" },
    { name: data.title, url },
  ]),
];
---

<BaseLayout
  title={data.title}
  description={data.description}
  type="article"
  image={data.cover?.src}
  publishedTime={data.pubDate.toISOString()}
  modifiedTime={data.updatedDate?.toISOString()}
  schemas={schemas}
>
  <div class="read-progress" aria-hidden="true"><span></span></div>
  <article class="article" style={`--pillar:${accent}`}>
    <div class="container-x">
      <Breadcrumbs items={[{ name: "Blog", url: "/blog/" }, { name: data.title, url }]} />

      <header class="art-head">
        <span class="art-tag" style={`--pillar:${accent}`}>{categoryLabel(data.category)}</span>
        <h1 class="art-title" data-reveal>{data.title}</h1>
        <p class="art-desc" data-reveal>{data.description}</p>
        <div class="art-meta" data-reveal>
          <span class="art-author">
            <span class="art-avatar">
              <span aria-hidden="true">CN</span>
              <img src="/images/crispus-njumwa.jpg" alt={data.author} loading="lazy" width="32" height="32" onerror="this.remove()" />
            </span>
            {data.author}
          </span>
          <span><Icon name="lucide:calendar" /> {fmt(data.pubDate)}</span>
          <span><Icon name="lucide:clock" /> {minutes} min read</span>
          {data.updatedDate && <span>Updated {fmt(data.updatedDate)}</span>}
        </div>
      </header>

      <div class="art-cover" data-reveal>
        <BlogCover category={data.category} title={data.title} cover={data.cover} coverAlt={data.coverAlt} />
      </div>

      <div class="art-grid">
        {toc.length > 2 && (
          <aside class="toc" aria-label="Table of contents">
            <p class="toc-title">On this page</p>
            <ul>
              {toc.map((h) => (
                <li class:list={[{ "toc-sub": h.depth === 3 }]}><a href={`#${h.slug}`}>{h.text}</a></li>
              ))}
            </ul>
          </aside>
        )}

        <div class="art-body">
          <Prose>
            <Content />
          </Prose>

          <div class="share">
            <span>Share:</span>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${site.url}${url}`}
              target="_blank"
              rel="noopener"
              aria-label="Share on LinkedIn"
            >
              <Icon name="lucide:linkedin" />
            </a>
            <a
              href={`https://twitter.com/intent/tweet?url=${site.url}${url}&text=${encodeURIComponent(data.title)}`}
              target="_blank"
              rel="noopener"
              aria-label="Share on X"
            >
              <Icon name="lucide:twitter" />
            </a>
            <a
              href={`https://wa.me/?text=${encodeURIComponent(data.title + " " + site.url + url)}`}
              target="_blank"
              rel="noopener"
              aria-label="Share on WhatsApp"
            >
              <Icon name="lucide:message-circle" />
            </a>
          </div>

          <div class="author-box">
            <div class="author-avatar">
              <span aria-hidden="true">CN</span>
              <img src="/images/crispus-njumwa.jpg" alt={data.author} loading="lazy" width="56" height="56" onerror="this.remove()" />
            </div>
            <div>
              <p class="author-name">{data.author}</p>
              <p class="author-bio">
                Microsoft-certified Dynamics 365 Finance & Operations technical consultant
                (Solution Architect Expert ×3). I build software, AI automation, mobile apps and data
                systems for businesses worldwide.
                <a href="/about/" class="link-underline">More about me</a> ·
                <a href={site.socials.linkedin} target="_blank" rel="noopener" class="link-underline">LinkedIn</a>
              </p>
            </div>
          </div>

          {pillar && (
            <a href={pillar.href} class="context-cta">
              <span>
                <span class="cc-label">Related service</span>
                <span class="cc-title">{pillar.title}</span>
              </span>
              <Icon name="lucide:arrow-right" />
            </a>
          )}
        </div>
      </div>
    </div>
  </article>

  {related.length > 0 && (
    <section class="section related-section">
      <div class="container-x">
        <h2 class="related-h">Keep reading</h2>
        <div class="related-grid">
          {related.map((p) => (
            <a href={`/blog/${p.id}/`} class="rel card-hover">
              <div class="rel-cover">
                <BlogCover category={p.data.category} title={p.data.title} cover={p.data.cover} coverAlt={p.data.coverAlt} />
              </div>
              <div class="rel-body">
                <span class="rel-tag">{categoryLabel(p.data.category)}</span>
                <h3 class="rel-title">{p.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTASection />

  <script>
    // Re-queries elements on each scroll so it stays correct across View Transitions;
    // the window listener is attached only once.
    const updateProgress = () => {
      const bar = document.querySelector<HTMLElement>(".read-progress span");
      const article = document.querySelector<HTMLElement>(".art-body");
      if (!bar || !article) return;
      const rect = article.getBoundingClientRect();
      const total = rect.height - window.innerHeight;
      const scrolled = Math.min(Math.max(-rect.top, 0), Math.max(total, 0));
      bar.style.width = (total > 0 ? (scrolled / total) * 100 : 0) + "%";
    };
    if (!(window as any).__progressBound) {
      window.addEventListener("scroll", updateProgress, { passive: true });
      (window as any).__progressBound = true;
    }
    updateProgress();
    document.addEventListener("astro:page-load", updateProgress);
  </script>
</BaseLayout>

<style>
  .article {
    padding-block: 1.5rem clamp(2rem, 5vw, 3rem);
  }
  .art-head {
    max-width: 52rem;
    margin: 1.5rem auto 0;
  }
  .read-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 60;
    background: transparent;
  }
  .read-progress span {
    display: block;
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-2));
  }
  .art-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--pillar, var(--color-accent-ink));
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--pillar, var(--color-accent)) 12%, transparent);
  }
  .art-title {
    margin-top: 0.8rem;
    font-size: clamp(1.9rem, 5vw, 3rem);
  }
  .art-author {
    font-weight: 500;
    color: var(--color-ink-soft);
  }
  .art-avatar {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-night);
    color: var(--color-accent);
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 600;
    margin-right: 0.1rem;
  }
  .art-avatar img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .art-desc {
    margin-top: 1rem;
    font-size: 1.15rem;
    color: var(--color-muted);
    line-height: 1.6;
  }
  .art-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-line);
    font-size: 0.88rem;
    color: var(--color-muted);
  }
  .art-meta span {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .art-meta svg {
    width: 1rem;
    height: 1rem;
  }
  .art-cover {
    width: 100%;
    max-width: 60rem;
    aspect-ratio: 16 / 8;
    overflow: hidden;
    margin: 2rem auto 0;
    border-radius: var(--radius-card);
    border: 1px solid var(--color-line);
  }
  .art-cover :global(.bc),
  .art-cover :global(.bc-svg),
  .art-cover :global(.bc-img) {
    width: 100%;
    height: 100%;
  }

  .art-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    max-width: 52rem;
    margin: 2.5rem auto 0;
  }
  .toc {
    align-self: start;
  }
  .toc-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }
  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-left: 2px solid var(--color-line);
  }
  .toc a {
    display: block;
    padding-left: 0.9rem;
    font-size: 0.88rem;
    color: var(--color-muted);
    line-height: 1.4;
  }
  .toc .toc-sub a {
    padding-left: 1.6rem;
    font-size: 0.82rem;
    opacity: 0.85;
  }
  .toc a:hover {
    color: var(--color-accent-ink);
  }

  .share {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-line);
    font-size: 0.88rem;
    color: var(--color-muted);
  }
  .share a {
    display: inline-flex;
    padding: 0.5rem;
    border: 1px solid var(--color-line);
    border-radius: 10px;
    transition: border-color 0.15s, color 0.15s;
  }
  .share a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-ink);
  }
  .share svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .author-box {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    padding: 1.5rem;
    background: var(--color-surface-2);
    border-radius: var(--radius-card);
  }
  .author-avatar {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    height: 3.25rem;
    flex-shrink: 0;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-night);
    color: var(--color-accent);
    font-family: var(--font-display);
    font-weight: 600;
  }
  .author-avatar img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .author-name {
    font-family: var(--font-display);
    font-weight: 600;
  }
  .author-bio {
    margin-top: 0.25rem;
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.55;
  }
  .author-bio a {
    color: var(--color-accent-ink);
    margin-left: 0.25rem;
  }

  .context-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-night);
    color: #fff;
    border-radius: var(--radius-card);
    transition: transform 0.18s var(--ease-out);
  }
  .context-cta:hover {
    transform: translateY(-2px);
  }
  .cc-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
  }
  .cc-title {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    margin-top: 0.2rem;
  }
  .context-cta svg {
    width: 1.3rem;
    height: 1.3rem;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .related-section {
    background: var(--color-surface-2);
  }
  .related-h {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .rel {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
  }
  .rel-cover {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .rel-cover :global(.bc),
  .rel-cover :global(.bc-svg),
  .rel-cover :global(.bc-img) {
    width: 100%;
    height: 100%;
  }
  .rel-body {
    padding: 1.3rem;
  }
  .rel-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    color: var(--color-accent-ink);
  }
  .rel-title {
    margin-top: 0.5rem;
    font-size: 1.05rem;
    line-height: 1.35;
  }

  @media (min-width: 640px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1080px) {
    .art-grid {
      grid-template-columns: 210px 1fr;
      gap: 3rem;
      max-width: 62rem;
    }
    .toc {
      position: sticky;
      top: 5.5rem;
      order: -1;
    }
    .toc ul {
      max-height: 70vh;
      overflow-y: auto;
    }
  }
</style>
