---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ContactForm from "@components/ContactForm.astro";
import FAQ from "@components/FAQ.astro";
import { Icon } from "astro-icon/components";
import { site, whatsappLink, mailtoLink } from "@data/site";
import { organizationSchema, breadcrumbSchema, faqSchema } from "@/lib/schema";

const calendly = import.meta.env.PUBLIC_CALENDLY_URL ?? site.calendly;

const methods = [
  { icon: "calendar-check", title: "Book a call", text: "Grab a free 20-minute slot — the fastest way to get clarity.", href: calendly, cta: "Open calendar", track: "book_call_contact", external: true, featured: true },
  { icon: "message-circle", title: "WhatsApp", text: site.phoneDisplay, href: whatsappLink, cta: "Start a chat", track: "whatsapp_contact", external: true, featured: false },
  { icon: "mail", title: "Email", text: site.email, href: mailtoLink, cta: "Send an email", track: "email_contact", external: false, featured: false },
];

const nextSteps = [
  { title: "You reach out", text: "Send a note below or book a call — whatever's easiest." },
  { title: "Free discovery call", text: "We talk through your goals, constraints and what success looks like." },
  { title: "Clear scope & price", text: "You get a written scope, timeline and fixed or milestone price." },
  { title: "We build & ship", text: "Focused iterations with regular demos — then launch and support." },
];

const trustChips = [
  { icon: "badge-check", label: "Microsoft Certified" },
  { icon: "award", label: "Solution Architect Expert ×3" },
  { icon: "building-2", label: "200+ user ERP go-live" },
  { icon: "clock", label: "Replies < 1 business day" },
];

const faqs = [
  { q: "How quickly will you respond?", a: "Within one business day — usually much faster. For urgent issues (like a database outage), mark it urgent on WhatsApp and I'll prioritize it." },
  { q: "How does an engagement start?", a: "With a free discovery call. We talk through your goals, I ask the right questions, and you get a clear scope, timeline and price before committing to anything." },
  { q: "Do you work with international clients?", a: "Yes — most of my clients are international (US, EU, UK and the Gulf), alongside Kenyan businesses. I keep delivery time-zone friendly and communication clear." },
  { q: "What information should I bring?", a: "Just the problem you're trying to solve and any constraints (timeline, budget, existing systems). You don't need a technical spec — that's my job." },
  { q: "What are your payment options?", a: "Bank transfer, card via Stripe, and M-Pesa. Projects usually run on a deposit plus milestones; retainers are billed monthly." },
];

const ogSchemas = [
  { "@context": "https://schema.org", "@type": "ContactPage", name: "Contact Njumwa Labs", url: `${site.url}/contact/` },
  organizationSchema(),
  breadcrumbSchema([{ name: "Home", url: "/" }, { name: "Contact", url: "/contact/" }]),
  faqSchema(faqs),
];
---

<BaseLayout
  title="Contact & book a call"
  description="Book a free call, message on WhatsApp, or send a project inquiry. Njumwa Labs replies within one business day — serving Kenya and clients worldwide."
  schemas={ogSchemas}
>
  <section class="contact-hero">
    <div class="container-x">
      <Breadcrumbs items={[{ name: "Contact", url: "/contact/" }]} />
      <span class="eyebrow ch-eyebrow" data-reveal>Contact</span>
      <h1 class="ch-title" data-reveal>Let's talk about your project.</h1>
      <p class="ch-sub" data-reveal>
        Pick whatever's easiest — book a call, message on WhatsApp, or send the form below. I reply
        within one business day.
      </p>
    </div>
  </section>

  <!-- Contact methods -->
  <section class="section methods-section">
    <div class="container-x">
      <div class="methods">
        {methods.map((m, i) => (
          <a
            href={m.href}
            class:list={["method", "card-hover", m.featured ? "card-gradient" : "card"]}
            data-track={m.track}
            data-reveal
            data-delay={String(i + 1)}
            {...(m.external ? { target: "_blank", rel: "noopener" } : {})}
          >
            <span class:list={["method-icon", { feat: m.featured }]}><Icon name={`lucide:${m.icon}`} /></span>
            <h2 class="method-title">{m.title}</h2>
            <p class="method-text">{m.text}</p>
            <span class="method-cta">{m.cta} <Icon name="lucide:arrow-up-right" /></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Form + trust panel -->
  <section class="section form-section bg-dots">
    <div class="container-x">
      <div class="form-grid">
        <div class="form-col" data-reveal>
          <div class="form-card">
            <span class="eyebrow">Send a message</span>
            <h2 class="form-title">Tell me what you're building.</h2>
            <p class="form-sub">
              The more detail you share, the better I can help. No detail too small — and no
              obligation.
            </p>
            <div id="form-success" class="form-success" hidden>
              <Icon name="lucide:check-circle-2" />
              <p>Thanks — your message came through. I'll be in touch within one business day.</p>
            </div>
            <ContactForm />
          </div>
        </div>

        <aside class="trust-col" data-reveal data-delay="1">
          <div class="trust-panel card-dark">
            <div class="trust-person">
              <span class="trust-avatar">
                <span class="trust-monogram" aria-hidden="true">CN</span>
                <img
                  class="trust-photo"
                  src="/images/crispus-njumwa.jpg"
                  alt={site.founder}
                  loading="lazy"
                  width="64"
                  height="64"
                  onerror="this.remove()"
                />
              </span>
              <div>
                <p class="trust-name">{site.founder}</p>
                <p class="trust-line">You'll be talking to me directly — not a sales team.</p>
              </div>
            </div>

            <h2 class="trust-title">What happens next</h2>
            <ol class="next-steps">
              {nextSteps.map((s) => (
                <li class="next-step">
                  <span class="ns-title">{s.title}</span>
                  <span class="ns-text">{s.text}</span>
                </li>
              ))}
            </ol>

            <ul class="trust-chips">
              {trustChips.map((c) => (
                <li class="trust-chip"><Icon name={`lucide:${c.icon}`} /> {c.label}</li>
              ))}
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Calendly booking -->
  <section class="section booking-section">
    <div class="container-x">
      <SectionHeading
        eyebrow="Or book directly"
        title="Grab a free 20-minute slot."
        text="Pick a time that suits you — no back-and-forth."
        align="center"
      />
      <div class="calendly-wrap" data-reveal>
        <button class="calendly-load" type="button" aria-label="Load booking calendar">
          <Icon name="lucide:calendar-check" />
          <span>Load the booking calendar</span>
          <small>Loads Calendly — opens in this page</small>
        </button>
        <template class="calendly-tpl" data-src={`${calendly}?hide_gdpr_banner=1`}></template>
      </div>
      <p class="booking-fallback">
        Prefer a new tab? <a href={calendly} target="_blank" rel="noopener" class="link-underline">Open the calendar</a>.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section">
    <div class="container-x">
      <SectionHeading eyebrow="Before you ask" title="Quick answers" align="center" />
      <div class="faq-wrap">
        <FAQ items={faqs} />
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const initContactPage = () => {
    // Success banner on the no-JS redirect path (?sent=1).
    if (new URLSearchParams(window.location.search).get("sent") === "1") {
      const el = document.getElementById("form-success");
      if (el) {
        el.hidden = false;
        el.scrollIntoView({ behavior: "smooth", block: "center" });
      }
    }

    // Lazy-load the Calendly embed only when the visitor asks for it (protects LCP/INP).
    const wrap = document.querySelector<HTMLDivElement>(".calendly-wrap");
    const btn = wrap?.querySelector<HTMLButtonElement>(".calendly-load");
    const tpl = wrap?.querySelector<HTMLTemplateElement>(".calendly-tpl");
    if (btn && tpl && wrap) {
      const load = () => {
        const src = tpl.dataset.src;
        if (!src) return;
        const iframe = document.createElement("iframe");
        iframe.src = src;
        iframe.title = "Book a call with Crispus Njumwa";
        iframe.loading = "lazy";
        iframe.width = "100%";
        iframe.height = "640";
        iframe.style.border = "0";
        btn.replaceWith(iframe);
      };
      btn.addEventListener("click", load, { once: true });
    }
  };
  initContactPage();
  document.addEventListener("astro:page-load", initContactPage);
</script>

<style>
  .contact-hero {
    position: relative;
    overflow: hidden;
    padding-block: 1.5rem clamp(1.5rem, 4vw, 2.5rem);
  }
  .contact-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(45% 60% at 85% 0%, color-mix(in srgb, var(--color-accent) 12%, transparent), transparent 70%);
    pointer-events: none;
  }
  .ch-eyebrow {
    display: block;
    margin-top: 1.5rem;
  }
  .ch-title {
    margin-top: 0.6rem;
    font-size: clamp(2rem, 5vw, 3.25rem);
  }
  .ch-sub {
    margin-top: 1rem;
    font-size: clamp(1.05rem, 2.2vw, 1.25rem);
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 50ch;
  }

  .methods-section {
    padding-top: 1rem;
  }
  .methods {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .method {
    display: flex;
    flex-direction: column;
    padding: 1.6rem;
  }
  .method-icon {
    display: inline-flex;
    width: 3rem;
    height: 3rem;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent-ink);
    margin-bottom: 1rem;
  }
  .method-icon.feat {
    background: rgba(255, 255, 255, 0.12);
    color: var(--color-accent);
  }
  .method-icon svg {
    width: 1.5rem;
    height: 1.5rem;
  }
  .method-title {
    font-size: 1.2rem;
  }
  .method-text {
    margin-top: 0.35rem;
    color: var(--color-muted);
    flex-grow: 1;
  }
  .card-gradient .method-text {
    color: rgba(255, 255, 255, 0.8);
  }
  .method-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 1.1rem;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--color-accent-ink);
  }
  .card-gradient .method-cta {
    color: var(--color-accent);
  }
  .method-cta svg {
    width: 1rem;
    height: 1rem;
  }

  /* form + trust two-column */
  .form-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  .form-card {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-lift);
    padding: clamp(1.5rem, 4vw, 2.25rem);
  }
  .form-title {
    margin-top: 0.5rem;
    font-size: clamp(1.5rem, 3vw, 2.1rem);
  }
  .form-sub {
    margin-top: 0.6rem;
    margin-bottom: 1.5rem;
    color: var(--color-muted);
    line-height: 1.55;
  }
  .form-success {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
    background: color-mix(in srgb, var(--color-accent) 14%, var(--color-surface));
    border: 1px solid var(--color-accent);
    border-radius: 12px;
    color: var(--color-accent-ink);
  }
  .form-success svg {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
  }
  .form-success p {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 500;
  }

  /* trust panel */
  .trust-panel {
    padding: clamp(1.5rem, 4vw, 2rem);
  }
  .trust-person {
    display: flex;
    gap: 0.85rem;
    align-items: center;
    padding-bottom: 1.25rem;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-night-line);
  }
  .trust-avatar {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    height: 3.25rem;
    flex-shrink: 0;
    border-radius: 50%;
    overflow: hidden;
    background: #0a1322;
    border: 2px solid transparent;
    background-image: linear-gradient(#0a1322, #0a1322),
      linear-gradient(140deg, var(--color-accent), var(--color-accent-2));
    background-origin: border-box;
    background-clip: content-box, border-box;
  }
  .trust-monogram {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-accent);
  }
  .trust-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }
  .trust-name {
    font-family: var(--font-display);
    font-weight: 600;
    color: #fff;
  }
  .trust-line {
    margin-top: 0.15rem;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.4;
  }
  .trust-title {
    font-size: 1.1rem;
    color: #fff;
  }
  .next-steps {
    list-style: none;
    counter-reset: ns;
    padding: 0;
    margin: 1rem 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .next-step {
    counter-increment: ns;
    position: relative;
    padding-left: 2.4rem;
  }
  .next-step::before {
    content: counter(ns);
    position: absolute;
    left: 0;
    top: 0;
    width: 1.7rem;
    height: 1.7rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-accent) 18%, transparent);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
  }
  .ns-title {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: #fff;
  }
  .ns-text {
    display: block;
    margin-top: 0.1rem;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.45;
  }
  .trust-chips {
    list-style: none;
    padding: 1.25rem 0 0;
    margin: 0;
    border-top: 1px solid var(--color-night-line);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .trust-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.76rem;
    padding: 0.35rem 0.65rem;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid var(--color-night-line);
    color: rgba(255, 255, 255, 0.85);
  }
  .trust-chip svg {
    width: 0.9rem;
    height: 0.9rem;
    color: var(--color-accent);
  }

  /* calendly */
  .booking-section {
    background: var(--color-surface-2);
  }
  .calendly-wrap {
    max-width: 52rem;
    margin: 1.5rem auto 0;
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--color-line);
    background: var(--color-surface);
  }
  .calendly-load {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    min-height: 16rem;
    padding: 2rem;
    border: 0;
    cursor: pointer;
    background: transparent;
    color: var(--color-ink);
    transition: background-color 0.18s;
  }
  .calendly-load:hover {
    background: color-mix(in srgb, var(--color-accent) 6%, var(--color-surface));
  }
  .calendly-load svg {
    width: 2.2rem;
    height: 2.2rem;
    color: var(--color-accent-ink);
  }
  .calendly-load span {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
  }
  .calendly-load small {
    font-size: 0.82rem;
    color: var(--color-muted);
  }
  .calendly-wrap :global(iframe) {
    display: block;
    border: 0;
  }
  .booking-fallback {
    margin-top: 0.85rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-muted);
  }
  .booking-fallback a {
    color: var(--color-accent-ink);
  }

  .faq-section :global(.eyebrow) {
    text-align: center;
  }
  .faq-wrap {
    max-width: 48rem;
    margin-inline: auto;
  }

  @media (min-width: 720px) {
    .methods {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 980px) {
    .form-grid {
      grid-template-columns: 1.25fr 0.85fr;
      gap: 2rem;
    }
  }
</style>
