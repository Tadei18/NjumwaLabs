---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ServiceCard from "@components/ServiceCard.astro";
import BenefitBlock from "@components/BenefitBlock.astro";
import ProcessSteps from "@components/ProcessSteps.astro";
import Testimonial from "@components/Testimonial.astro";
import CaseStudyCard from "@components/CaseStudyCard.astro";
import CredentialsBand from "@components/CredentialsBand.astro";
import LogoCloud from "@components/LogoCloud.astro";
import Stat from "@components/Stat.astro";
import CTASection from "@components/CTASection.astro";
import { Icon } from "astro-icon/components";
import { pillars } from "@data/services";
import { testimonials } from "@data/testimonials";
import { getCollection } from "astro:content";

const featured = (await getCollection("portfolio", ({ data }) => !data.draft && data.featured))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const why = [
  {
    icon: "award",
    title: "Microsoft-certified, enterprise-proven",
    text: "Three Microsoft Solution Architect Expert certifications and a 200+ user D365 ERP go-live behind me — I bring enterprise rigour to projects of every size.",
  },
  {
    icon: "layers",
    title: "Full-stack range",
    text: "Web, mobile, AI automation, databases and ERP under one roof. Fewer vendors, fewer handoffs, one partner who sees the whole system.",
  },
  {
    icon: "wallet",
    title: "Globally affordable",
    text: "Enterprise quality at prices well below typical US/EU agencies — so SMEs and startups can afford to build things properly.",
  },
  {
    icon: "message-square-text",
    title: "Reliable & clear",
    text: "Regular demos, plain-language updates and dependable delivery. You always know where your project stands.",
  },
];

const automationScenarios = [
  { before: "Leads answered overnight", after: "Answered in 2 seconds, 24/7", icon: "message-circle" },
  { before: "10 hrs/week of data entry", after: "0 — fully automated", icon: "file-spreadsheet" },
  { before: "Missed calls = lost sales", after: "Every call captured & booked", icon: "phone-call" },
];

const description =
  "Njumwa Labs builds software, AI automation, mobile apps, databases and Dynamics 365 systems that grow your business — enterprise-grade delivery at globally affordable prices, from Nairobi to the world.";
---

<BaseLayout
  title="Software, automation & data systems that grow your business"
  description={description}
  isHome={true}
>
  <Hero />

  <!-- Trust strip -->
  <section class="section trust-strip" id="explore">
    <div class="container-x">
      <LogoCloud heading="Trusted by businesses in Kenya, the US, EU & the Gulf — built with" marquee={true} />
      <div class="stats">
        <Stat value="5" label="Service pillars, one connected system" />
        <Stat value="D365" label="Enterprise ERP consulting background" />
        <Stat value="24/7" label="Automations that never clock off" />
        <Stat value="< 1 day" label="Typical first response" />
      </div>
    </div>
  </section>

  <!-- Services overview -->
  <section class="section bg-dots">
    <div class="container-x">
      <SectionHeading
        eyebrow="What I do"
        title="Five capabilities. One business operating system."
        text="Each service stands on its own — or combines into a single system where your website, app, data, automations and ERP all talk to each other."
      />
      <div class="services-grid">
        {pillars.map((p, i) => (
          <ServiceCard pillar={p} index={i} />
        ))}
        <a href="/services/" class="service-all card-gradient card-hover" data-reveal>
          <svg class="sa-nodes" viewBox="0 0 120 120" fill="none" aria-hidden="true">
            <line x1="60" y1="60" x2="60" y2="22" stroke="currentColor" stroke-width="1.5" />
            <line x1="60" y1="60" x2="94" y2="44" stroke="currentColor" stroke-width="1.5" />
            <line x1="60" y1="60" x2="84" y2="96" stroke="currentColor" stroke-width="1.5" />
            <line x1="60" y1="60" x2="30" y2="92" stroke="currentColor" stroke-width="1.5" />
            <line x1="60" y1="60" x2="24" y2="40" stroke="currentColor" stroke-width="1.5" />
            <circle cx="60" cy="22" r="6" fill="currentColor" />
            <circle cx="94" cy="44" r="6" fill="currentColor" />
            <circle cx="84" cy="96" r="6" fill="currentColor" />
            <circle cx="30" cy="92" r="6" fill="currentColor" />
            <circle cx="24" cy="40" r="6" fill="currentColor" />
            <circle cx="60" cy="60" r="9" fill="#0a1322" stroke="currentColor" stroke-width="2" />
          </svg>
          <span class="sa-label">See how they fit together</span>
          <span class="sa-arrow">Explore the system <Icon name="lucide:arrow-right" /></span>
        </a>
      </div>
    </div>
  </section>

  <!-- Why work with me -->
  <section class="section why">
    <div class="container-x">
      <SectionHeading
        eyebrow="Why Njumwa Labs"
        title="The technical partner who can build it, automate it, and keep it running."
      />
      <div class="why-grid">
        {why.map((w) => (
          <BenefitBlock icon={w.icon} title={w.title} text={w.text} />
        ))}
      </div>
    </div>
  </section>

  <!-- AI automation spotlight (showpiece, dark) -->
  <section class="section section-dark spotlight">
    <span class="glow glow-cyan spot-glow" aria-hidden="true"></span>
    <div class="container-x">
      <div class="spotlight-inner">
        <div class="spotlight-copy" data-reveal>
          <span class="eyebrow">In focus · highest demand</span>
          <h2 class="spotlight-title">Put your repetitive work <span class="text-gradient">on autopilot.</span></h2>
          <p class="spotlight-text">
            AI automation is where most businesses find the fastest return: faster responses, more
            qualified leads, and hours of manual work removed every week. Here's what that looks
            like in practice.
          </p>
          <a href="/services/ai-automation/" class="btn btn-primary">
            Explore AI automation
            <Icon name="lucide:arrow-right" />
          </a>
        </div>
        <ul class="scenarios">
          {automationScenarios.map((s, i) => (
            <li class="scenario" data-reveal data-delay={String(i + 1)}>
              <span class="scenario-icon"><Icon name={`lucide:${s.icon}`} /></span>
              <div class="scenario-flow">
                <span class="scenario-before">{s.before}</span>
                <Icon name="lucide:arrow-right" class="scenario-arrow" />
                <span class="scenario-after">{s.after}</span>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div class="spot-stats">
        <div class="spot-stat" data-reveal>
          <span class="spot-num"><span data-count="2" data-suffix="s">2s</span></span>
          <span class="spot-label">to first reply, day or night</span>
        </div>
        <div class="spot-stat" data-reveal data-delay="1">
          <span class="spot-num"><span data-count="24" data-suffix="/7">24/7</span></span>
          <span class="spot-label">always-on coverage</span>
        </div>
        <div class="spot-stat" data-reveal data-delay="2">
          <span class="spot-num"><span data-count="10" data-suffix="+ hrs">10+ hrs</span></span>
          <span class="spot-label">manual work removed weekly</span>
        </div>
        <div class="spot-stat" data-reveal data-delay="3">
          <span class="spot-num"><span data-count="0" data-suffix="">0</span></span>
          <span class="spot-label">leads left unanswered</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured work -->
  {featured.length > 0 && (
    <section class="section">
      <div class="container-x">
        <SectionHeading
          eyebrow="Selected work"
          title="Systems that delivered measurable results."
          text="A few representative projects. Each one started as a business problem, not a feature list."
        />
        <div class="work-grid">
          {featured.map((cs) => (
            <CaseStudyCard
              url={`/portfolio/${cs.id}/`}
              title={cs.data.title}
              description={cs.data.description}
              client={cs.data.client}
              industry={cs.data.industry}
              pillar={cs.data.pillar}
              cover={cs.data.cover}
              coverAlt={cs.data.coverAlt}
              metrics={cs.data.metrics}
            />
          ))}
        </div>
        <div class="center-cta">
          <a href="/portfolio/" class="btn btn-ghost">See all work <Icon name="lucide:arrow-right" /></a>
        </div>
      </div>
    </section>
  )}

  <!-- Process -->
  <section class="section process">
    <div class="container-x">
      <SectionHeading
        eyebrow="How it works"
        title="A clear path from idea to working system."
        text="No mystery, no runaway scope. Four simple stages, with you in the loop the whole way."
      />
      <ProcessSteps />
    </div>
  </section>

  <!-- Credentials / trust band (dark) -->
  <section class="section section-dark">
    <div class="container-x">
      <CredentialsBand variant="dark" />
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section bg-dots">
    <div class="container-x">
      <SectionHeading
        eyebrow="In their words"
        title="What working together feels like."
        align="center"
      />
      <div class="testimonials-grid">
        {testimonials.slice(0, 3).map((t) => (
          <Testimonial testimonial={t} />
        ))}
      </div>
      <p class="placeholder-note">Placeholder testimonials — real client quotes land here as projects wrap.</p>
    </div>
  </section>

  <!-- Pricing teaser -->
  <section class="section pricing-teaser">
    <div class="container-x">
      <SectionHeading
        eyebrow="Pricing"
        title="Transparent, globally affordable pricing."
        text="Clear 'from' prices in USD. Local (KES) and custom quotes available — no surprises, ever."
      />
      <div class="teaser-grid">
        {pillars.map((p) => (
          <a href={p.href} class="teaser-item" data-reveal>
            <span class="teaser-name">{p.short}</span>
            <span class="teaser-price">from {p.priceFrom}</span>
          </a>
        ))}
      </div>
      <div class="center-cta">
        <a href="/pricing/" class="btn btn-primary">See full pricing <Icon name="lucide:arrow-right" /></a>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<style>
  .trust-strip {
    padding-block: clamp(2rem, 5vw, 3.5rem);
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem 1.5rem;
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-line);
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .service-all {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.4rem;
    padding: 1.6rem;
    min-height: 14rem;
  }
  .sa-nodes {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 6.5rem;
    height: 6.5rem;
    color: var(--color-accent);
    opacity: 0.8;
  }
  .sa-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
    line-height: 1.2;
    max-width: 12ch;
  }
  .sa-arrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-accent);
  }
  .sa-arrow svg {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s var(--ease-out);
  }
  .service-all:hover .sa-arrow svg {
    transform: translateX(4px);
  }

  .why {
    background: var(--color-surface-2);
  }
  .why-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .spotlight {
    position: relative;
  }
  .spot-glow {
    width: 34rem;
    height: 34rem;
    top: -10rem;
    right: -8rem;
    opacity: 0.22;
  }
  .spotlight-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  .spotlight-title {
    margin-top: 0.6rem;
    font-size: clamp(1.7rem, 4vw, 2.6rem);
  }
  .spotlight-text {
    margin-top: 1rem;
    color: rgba(255, 255, 255, 0.74);
    line-height: 1.6;
    max-width: 46ch;
  }
  .spotlight-copy .btn {
    margin-top: 1.5rem;
  }
  .spotlight-copy svg {
    width: 1.1rem;
    height: 1.1rem;
  }
  .scenarios {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .scenario {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-night-line);
    border-radius: var(--radius-card);
    transition: border-color 0.2s, transform 0.2s var(--ease-out);
  }
  .scenario:hover {
    border-color: color-mix(in srgb, var(--color-accent) 55%, transparent);
    transform: translateX(4px);
  }
  .scenario-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    flex-shrink: 0;
    border-radius: 12px;
    background: color-mix(in srgb, var(--color-accent) 16%, transparent);
    color: var(--color-accent);
  }
  .scenario-icon svg {
    width: 1.4rem;
    height: 1.4rem;
  }
  .scenario-flow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .scenario-before {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: line-through;
    text-decoration-color: rgba(255, 255, 255, 0.3);
  }
  .scenario-arrow {
    width: 1.1rem;
    height: 1.1rem;
    color: var(--color-accent);
    flex-shrink: 0;
  }
  .scenario-after {
    font-family: var(--font-display);
    font-weight: 600;
    color: #fff;
  }

  .spot-stats {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem 1rem;
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-night-line);
  }
  .spot-stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .spot-num {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    line-height: 1;
    color: var(--color-accent);
  }
  .spot-label {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.66);
    line-height: 1.4;
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .center-cta {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }
  .center-cta svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .process {
    background: var(--color-surface-2);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .placeholder-note {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.82rem;
    color: var(--color-muted);
    font-style: italic;
  }

  .teaser-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  .teaser-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.4rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 14px;
    transition: border-color 0.18s, transform 0.18s var(--ease-out);
  }
  .teaser-item:hover {
    border-color: var(--color-accent);
    transform: translateX(4px);
  }
  .teaser-name {
    font-family: var(--font-display);
    font-weight: 500;
  }
  .teaser-price {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-accent-ink);
  }

  @media (min-width: 640px) {
    .stats {
      grid-template-columns: repeat(4, 1fr);
    }
    .services-grid,
    .why-grid,
    .work-grid,
    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .teaser-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 980px) {
    .services-grid,
    .work-grid,
    .testimonials-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .why-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .spotlight-inner {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
