---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import CaseStudyCard from "@components/CaseStudyCard.astro";
import CTASection from "@components/CTASection.astro";
import { pillars } from "@data/services";
import { breadcrumbSchema } from "@/lib/schema";
import { getCollection } from "astro:content";

const items = (await getCollection("portfolio", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

// Only show filter chips for pillars that actually have work.
const usedPillars = pillars.filter((p) => items.some((i) => i.data.pillar === p.slug));

// Headline proof metrics for the hero (count up on load).
const heroStats = [
  { count: "200", prefix: "", suffix: "+", label: "users on a D365 go-live" },
  { count: "62", prefix: "", suffix: "%", label: "faster app after tuning" },
  { count: "6", prefix: "", suffix: " wks", label: "idea to shipped MVP" },
];
---

<BaseLayout
  title="Portfolio & case studies"
  description="Selected software, automation, mobile and database projects — each one a real business problem solved, with measurable results."
  schemas={[breadcrumbSchema([{ name: "Home", url: "/" }, { name: "Portfolio", url: "/portfolio/" }])]}
>
  <PageHero
    eyebrow="Portfolio"
    title="Real problems, "
    titleAccent="measurable results."
    subtitle="Each project started as a business problem — slow systems, manual work, missed leads — and ended as a working system that moved a number that mattered."
    breadcrumbs={[{ name: "Portfolio", url: "/portfolio/" }]}
    visual="panel"
  >
    <div class="results">
      <p class="results-label">Outcomes that mattered</p>
      <div class="results-strip">
        {heroStats.map((s) => (
          <div class="result">
            <span class="result-num" data-count={s.count} data-prefix={s.prefix} data-suffix={s.suffix}>
              {s.prefix}{s.count}{s.suffix}
            </span>
            <span class="result-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </PageHero>

  <section class="section">
    <div class="container-x">
      <div class="filters" role="tablist" aria-label="Filter by service">
        <button class="filter active" data-filter="all" role="tab" aria-selected="true">All</button>
        {usedPillars.map((p) => (
          <button class="filter" data-filter={p.slug} role="tab" aria-selected="false">{p.short}</button>
        ))}
      </div>

      <div class="pf-grid">
        {items.map((cs) => (
          <div class="pf-item" data-pillar={cs.data.pillar}>
            <CaseStudyCard
              url={`/portfolio/${cs.id}/`}
              title={cs.data.title}
              description={cs.data.description}
              client={cs.data.client}
              industry={cs.data.industry}
              pillar={cs.data.pillar}
              cover={cs.data.cover}
              coverAlt={cs.data.coverAlt}
              metrics={cs.data.metrics}
            />
          </div>
        ))}
      </div>
      <p class="pf-note">More case studies are on the way as current projects wrap.</p>
    </div>
  </section>

  <CTASection heading="Want results like these for your business?" />
</BaseLayout>

<script>
  const initFilter = () => {
    const filters = document.querySelectorAll<HTMLButtonElement>(".filter");
    const items = document.querySelectorAll<HTMLElement>(".pf-item");
    filters.forEach((btn) => {
      btn.addEventListener("click", () => {
        const f = btn.dataset.filter;
        filters.forEach((b) => {
          const on = b === btn;
          b.classList.toggle("active", on);
          b.setAttribute("aria-selected", String(on));
        });
        items.forEach((item) => {
          item.style.display = f === "all" || item.dataset.pillar === f ? "" : "none";
        });
      });
    });
  };
  initFilter();
  document.addEventListener("astro:page-load", initFilter);
</script>

<style>
  .results-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 1rem;
  }
  .results-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }
  .result {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.9rem 0.5rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-night-line);
    border-radius: 14px;
    text-align: center;
  }
  .result-num {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: clamp(1.5rem, 4.5vw, 2.1rem);
    line-height: 1;
    color: var(--color-accent);
  }
  .result-label {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.68);
    line-height: 1.3;
  }
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .filter {
    border: 1px solid var(--color-line);
    background: var(--color-surface);
    cursor: pointer;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.88rem;
    color: var(--color-muted);
    transition: all 0.15s;
  }
  .filter.active {
    background: var(--color-ink);
    color: #fff;
    border-color: var(--color-ink);
  }
  .pf-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .pf-note {
    text-align: center;
    margin-top: 2rem;
    font-size: 0.85rem;
    color: var(--color-muted);
    font-style: italic;
  }
  @media (min-width: 640px) {
    .pf-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 980px) {
    .pf-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
