---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import SectionHeading from "@components/SectionHeading.astro";
import PricingTable from "@components/PricingTable.astro";
import FAQ from "@components/FAQ.astro";
import CTASection from "@components/CTASection.astro";
import { Icon } from "astro-icon/components";
import { breadcrumbSchema, faqSchema } from "@/lib/schema";

const reassurances = [
  { icon: "globe", text: "Prices in USD — local KES and custom quotes always available" },
  { icon: "file-text", text: "Clear scope and fixed or milestone pricing — no surprise invoices" },
  { icon: "handshake", text: "Free discovery call before any commitment" },
];

const faqs = [
  { q: "Are these prices fixed?", a: "They're transparent 'from' anchors so you know roughly where things start. Your actual quote depends on scope — which I'll confirm in writing before we begin. No hidden costs." },
  { q: "Do you offer local (Kenyan) pricing?", a: "Yes. Prices are shown in USD for clarity, but I offer local KES rates and flexible terms for Kenyan businesses. Just <a href='/contact/'>ask for a local quote</a>." },
  { q: "How do payments work?", a: "Typically a deposit to start, then milestone payments for projects, or monthly billing for retainers. I accept bank transfer, card (Stripe) and M-Pesa." },
  { q: "What if I'm not sure which package I need?", a: "That's exactly what the free call is for. Tell me the problem and I'll recommend the smallest thing that solves it — even if that's a smaller package than you expected." },
  { q: "Can I start small and grow?", a: "Absolutely. Many clients start with a focused project, then move to a retainer for ongoing improvements once it's live." },
  { q: "Do you require a long contract?", a: "No. Projects are scoped per engagement, and retainers are month-to-month — you can cancel anytime." },
];
---

<BaseLayout
  title="Pricing & packages"
  description="Transparent, globally affordable pricing for web, AI automation, mobile, database and Dynamics 365 work. Projects from $600, retainers from $300/month. USD with local KES quotes available."
  schemas={[
    breadcrumbSchema([{ name: "Home", url: "/" }, { name: "Pricing", url: "/pricing/" }]),
    faqSchema(faqs.map((f) => ({ q: f.q, a: f.a.replace(/<[^>]+>/g, "") }))),
  ]}
>
  <section class="pricing-hero">
    <span class="glow glow-cyan pr-glow" aria-hidden="true"></span>
    <div class="container-x">
      <Breadcrumbs items={[{ name: "Pricing", url: "/pricing/" }]} />
      <div class="pr-grid">
        <div class="pr-copy">
          <span class="eyebrow pr-eyebrow" data-reveal>Pricing</span>
          <h1 class="pr-title" data-reveal>
            Enterprise quality, without the <span class="text-gradient">enterprise price tag.</span>
          </h1>
          <p class="pr-sub" data-reveal>
            Clear packages and honest 'from' prices. Built to be affordable for SMEs and startups
            while delivering work that holds up to international standards.
          </p>
          <ul class="reassurance" data-reveal>
            {reassurances.map((r) => (
              <li><span class="re-icon"><Icon name={`lucide:${r.icon}`} /></span> {r.text}</li>
            ))}
          </ul>
        </div>

        <aside class="pr-visual card-gradient" data-reveal aria-hidden="true">
          <div class="pv-head">
            <span class="pv-label">value vs. price</span>
            <span class="pv-tag">globally affordable</span>
          </div>
          <div class="pv-bars">
            <div class="pv-row">
              <span class="pv-name">Value delivered</span>
              <span class="pv-bar"><i style="width:94%"></i></span>
            </div>
            <div class="pv-row">
              <span class="pv-name">Typical agency price</span>
              <span class="pv-bar"><i style="width:80%;background:rgba(255,255,255,.25)"></i></span>
            </div>
            <div class="pv-row">
              <span class="pv-name">My price</span>
              <span class="pv-bar"><i class="pv-mine" style="width:34%"></i></span>
            </div>
          </div>
          <div class="pv-chips">
            <span class="pv-chip"><Icon name="lucide:badge-check" /> Microsoft Certified</span>
            <span class="pv-chip"><Icon name="lucide:award" /> Solution Architect Expert ×3</span>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-x">
      <PricingTable />
    </div>
  </section>

  <section class="section faq-section">
    <div class="container-x">
      <SectionHeading eyebrow="Pricing FAQ" title="Questions about working together" align="center" />
      <div class="faq-wrap">
        <FAQ items={faqs} />
      </div>
    </div>
  </section>

  <CTASection heading="Not sure what it'll cost? Let's scope it together." text="Tell me what you're trying to build. I'll come back with a clear recommendation and a fair price — usually within a day." />
</BaseLayout>

<style>
  .pricing-hero {
    position: relative;
    overflow: hidden;
    padding-block: 1.5rem clamp(2.5rem, 6vw, 4rem);
  }
  .pr-glow {
    width: 32rem;
    height: 32rem;
    top: -12rem;
    right: -10rem;
    opacity: 0.16;
  }
  .pr-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
    margin-top: 1.5rem;
  }
  .pr-eyebrow {
    display: block;
  }
  .pr-title {
    margin-top: 0.6rem;
    font-size: clamp(2rem, 5vw, 3.25rem);
    max-width: 16ch;
  }
  .pr-sub {
    margin-top: 1.1rem;
    font-size: clamp(1.05rem, 2.2vw, 1.25rem);
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 50ch;
  }
  .reassurance {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    list-style: none;
    padding: 0;
    margin: 1.75rem 0 0;
    font-size: 0.92rem;
    color: var(--color-ink-soft);
  }
  .reassurance li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .re-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.9rem;
    height: 1.9rem;
    flex-shrink: 0;
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-accent) 14%, transparent);
    color: var(--color-accent-ink);
  }
  .re-icon svg {
    width: 1.05rem;
    height: 1.05rem;
  }

  /* visual anchor */
  .pr-visual {
    padding: 1.6rem;
  }
  .pv-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.4rem;
  }
  .pv-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.6);
  }
  .pv-tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    padding: 0.2rem 0.55rem;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-accent);
  }
  .pv-bars {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .pv-row {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .pv-name {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.72);
  }
  .pv-bar {
    height: 0.6rem;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.08);
    overflow: hidden;
  }
  .pv-bar i {
    display: block;
    height: 100%;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.4);
  }
  .pv-mine {
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-2)) !important;
  }
  .pv-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-night-line);
  }
  .pv-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    padding: 0.35rem 0.7rem;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid var(--color-night-line);
    color: rgba(255, 255, 255, 0.85);
  }
  .pv-chip svg {
    width: 0.95rem;
    height: 0.95rem;
    color: var(--color-accent);
  }
  @media (min-width: 900px) {
    .pr-grid {
      grid-template-columns: 1.15fr 0.85fr;
      gap: 3rem;
    }
  }
  .faq-section {
    background: var(--color-surface-2);
  }
  .faq-wrap {
    max-width: 48rem;
    margin-inline: auto;
  }
  @media (min-width: 820px) {
    .reassurance {
      flex-direction: row;
      justify-content: center;
      gap: 1.75rem;
    }
  }
</style>
