---
import BaseLayout from "@layouts/BaseLayout.astro";
import PillarHero from "@components/PillarHero.astro";
import SectionHeading from "@components/SectionHeading.astro";
import OfferingList from "@components/OfferingList.astro";
import BenefitBlock from "@components/BenefitBlock.astro";
import ProcessSteps from "@components/ProcessSteps.astro";
import CaseStudyCard from "@components/CaseStudyCard.astro";
import FAQ from "@components/FAQ.astro";
import CTASection from "@components/CTASection.astro";
import CredentialsBand from "@components/CredentialsBand.astro";
import KeyTakeaways from "@components/KeyTakeaways.astro";
import RelatedContent from "@components/RelatedContent.astro";
import { Icon } from "astro-icon/components";
import { pillars, pillarBySlug } from "@data/services";
import { pillarContent } from "@data/pillarContent";
import { serviceSchema, breadcrumbSchema, faqSchema } from "@/lib/schema";
import { getCollection } from "astro:content";
import type { RelatedLink } from "@components/RelatedContent.astro";

// Cross-links from each pillar to relevant comparison/cost/glossary resources.
const resourceLinks: Record<string, RelatedLink[]> = {
  "web-development": [
    { label: "How much does a website cost?", href: "/cost/website-cost/", kind: "cost" },
    { label: "Headless CMS vs WordPress", href: "/compare/headless-vs-wordpress/", kind: "compare" },
    { label: "Core Web Vitals — glossary", href: "/glossary/core-web-vitals/", kind: "glossary" },
  ],
  "ai-automation": [
    { label: "Automation ROI calculator", href: "/tools/automation-roi-calculator/", kind: "tool" },
    { label: "Power Apps vs custom app", href: "/compare/power-apps-vs-custom-app/", kind: "compare" },
    { label: "RAG & AI agents — glossary", href: "/glossary/rag/", kind: "glossary" },
    { label: "AI automation for real estate", href: "/industries/ai-automation-for-real-estate/", kind: "post" },
  ],
  "mobile-apps": [
    { label: "App cost estimator", href: "/tools/app-cost-estimator/", kind: "tool" },
    { label: "How much does a mobile app cost?", href: "/cost/mobile-app-cost/", kind: "cost" },
    { label: "Flutter vs React Native", href: "/compare/flutter-vs-react-native/", kind: "compare" },
  ],
  "database-administration": [
    { label: "PostgreSQL vs MongoDB", href: "/compare/postgresql-vs-mongodb/", kind: "compare" },
    { label: "Query optimization — glossary", href: "/glossary/query-optimization/", kind: "glossary" },
    { label: "High availability — glossary", href: "/glossary/high-availability/", kind: "glossary" },
  ],
  "dynamics-365-finance-operations": [
    { label: "D365 customization cost", href: "/cost/d365-customization-cost/", kind: "cost" },
    { label: "Dynamics 365 ERP for insurance", href: "/industries/erp-for-insurance/", kind: "post" },
    { label: "X++ & Chain of Command — glossary", href: "/glossary/x-plus-plus/", kind: "glossary" },
  ],
};

export async function getStaticPaths() {
  return pillars.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const pillar = pillarBySlug(slug!)!;
const content = pillarContent[slug!];
const isD365 = slug === "dynamics-365-finance-operations";
const isAI = slug === "ai-automation";

// D365 enterprise go-live proof (anonymized — see README "pending approval").
const goLiveModules = [
  { icon: "book-open", label: "General Ledger" },
  { icon: "hand-coins", label: "Accounts Receivable" },
  { icon: "receipt", label: "Accounts Payable" },
  { icon: "building", label: "Fixed Assets" },
  { icon: "boxes", label: "Inventory" },
  { icon: "shopping-cart", label: "Procurement & Sourcing" },
];
const goLiveWork = [
  "Designed and developed custom AOT elements — tables, forms, classes, data entities, and table/form extensions — in X++ using the Chain of Command pattern, extending standard F&O behaviour without breaking upgrade paths.",
  "Built SSRS and Power BI reports surfacing financial and operational KPIs for finance, claims and underwriting teams.",
  "Configured Data Management Framework (DMF) projects to migrate master data and historical transactions from legacy systems during cutover.",
  "Translated business requirements into technical specifications alongside senior architects across build, test, UAT and hypercare.",
  "Resolved post-go-live defects and tuned performance of high-volume transactional workflows in production.",
];

const related = (
  await getCollection("portfolio", ({ data }) => !data.draft && data.pillar === slug)
).slice(0, 3);

const breadcrumbs = [
  { name: "Services", url: "/services/" },
  { name: pillar.title, url: pillar.href },
];

const schemas = [
  serviceSchema({
    name: pillar.title,
    description: content.metaDescription,
    url: pillar.href,
    serviceType: content.serviceType,
  }),
  breadcrumbSchema([{ name: "Home", url: "/" }, ...breadcrumbs]),
  faqSchema(content.faqs.map((f) => ({ q: f.q, a: f.a.replace(/<[^>]+>/g, "") }))),
];
---

<BaseLayout title={content.metaTitle} description={content.metaDescription} schemas={schemas}>
  <PillarHero
    icon={pillar.icon}
    eyebrow={content.eyebrow}
    title={content.h1}
    subtitle={content.subtitle}
    priceFrom={pillar.priceFrom}
    breadcrumbs={breadcrumbs}
  />

  <div class="container-x tldr-wrap">
    <KeyTakeaways items={content.takeaways} />
  </div>

  {isD365 && (
    <>
      <!-- Credentials band -->
      <section class="section section-dark">
        <div class="container-x">
          <CredentialsBand variant="dark" />
        </div>
      </section>

      <!-- Proven on a real enterprise go-live -->
      <section class="section golive">
        <div class="container-x">
          <SectionHeading
            eyebrow="Proven delivery"
            title="Proven on a real enterprise go-live."
            text="I delivered technical components on a large-scale D365 Finance & Operations implementation and go-live serving 200–1,000 users at a leading East African insurance group — across six core finance and operations modules."
          />

          <div class="modules" data-reveal>
            {goLiveModules.map((m) => (
              <span class="module">
                <Icon name={`lucide:${m.icon}`} />
                {m.label}
              </span>
            ))}
          </div>

          <ul class="golive-work">
            {goLiveWork.map((w, i) => (
              <li class="golive-item" data-reveal data-delay={String((i % 3) + 1)}>
                <Icon name="lucide:check" />
                <span>{w}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
    </>
  )}

  {isAI && (
    <section class="ai-cred-wrap">
      <div class="container-x">
        <p class="ai-cred" data-reveal>
          <Icon name="lucide:sparkles" />
          Backed by Microsoft AI certification and an applied Machine Learning Specialization
          (DeepLearning.AI / Stanford) — plus hands-on ML projects, including a facial-recognition
          attendance system built with Python, OpenCV and DLIB.
        </p>
      </div>
    </section>
  )}

  <!-- Problem -->
  <section class="section problem">
    <div class="container-x">
      <div class="problem-inner" data-reveal>
        <span class="eyebrow">The problem</span>
        <h2 class="problem-title">{content.problem.title}</h2>
        <p class="problem-text prose-measure">{content.problem.text}</p>
      </div>
    </div>
  </section>

  <!-- Offerings -->
  <section class="section">
    <div class="container-x">
      <SectionHeading eyebrow="What's included" title="Everything this service covers" />
      <OfferingList items={content.offerings} />
    </div>
  </section>

  <!-- Benefits -->
  <section class="section benefits">
    <div class="container-x">
      <SectionHeading eyebrow="How this helps your business" title="The outcomes you can expect" />
      <div class="benefits-grid">
        {content.benefits.map((b) => (
          <BenefitBlock icon={b.icon} title={b.title} text={b.text} />
        ))}
      </div>

      {content.scenarios && (
        <ul class="scenarios">
          {content.scenarios.map((s) => (
            <li class="scenario" data-reveal>
              <span class="scenario-before">{s.before}</span>
              <Icon name="lucide:arrow-right" class="scenario-arrow" />
              <span class="scenario-after">{s.after}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <!-- Tools -->
  <section class="section">
    <div class="container-x">
      <SectionHeading eyebrow="Stack" title="Tools and platforms I use here" align="center" />
      <ul class="tools" data-reveal>
        {content.tools.map((t) => (
          <li class="tool">{t}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Process -->
  <section class="section process">
    <div class="container-x">
      <SectionHeading eyebrow="How it works" title="How we'll work together" />
      <ProcessSteps />
    </div>
  </section>

  <!-- Related work -->
  {related.length > 0 && (
    <section class="section">
      <div class="container-x">
        <SectionHeading eyebrow="Relevant work" title="Related case studies" />
        <div class="work-grid">
          {related.map((cs) => (
            <CaseStudyCard
              url={`/portfolio/${cs.id}/`}
              title={cs.data.title}
              description={cs.data.description}
              client={cs.data.client}
              industry={cs.data.industry}
              pillar={cs.data.pillar}
              cover={cs.data.cover}
              coverAlt={cs.data.coverAlt}
              metrics={cs.data.metrics}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Pricing snapshot -->
  <section class="section pricing-snap">
    <div class="container-x">
      <div class="snap-card" data-reveal>
        <div>
          <span class="eyebrow">Pricing</span>
          <h2 class="snap-title">{pillar.title} starts from {pillar.priceFrom}</h2>
          <p class="snap-text">Transparent USD pricing. Local (KES) and custom quotes available.</p>
        </div>
        <div class="snap-actions">
          <a href="/pricing/" class="btn btn-ghost">See pricing</a>
          <a href="/contact/" class="btn btn-primary" data-track="book_call_pillar_snap">Get a quote</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related resources -->
  <section class="section">
    <div class="container-x related-wrap">
      <RelatedContent links={resourceLinks[slug!] ?? []} title="Helpful resources" />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section">
    <div class="container-x">
      <SectionHeading eyebrow="FAQ" title="Common questions" align="center" />
      <div class="faq-wrap">
        <FAQ items={content.faqs} />
      </div>
    </div>
  </section>

  <CTASection heading={`Ready to get started with ${pillar.title.toLowerCase()}?`} />
</BaseLayout>

<style>
  .tldr-wrap {
    max-width: 56rem;
  }
  .ai-cred-wrap {
    padding-top: 1.5rem;
  }
  .ai-cred {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    max-width: 60rem;
    padding: 1.1rem 1.4rem;
    background: color-mix(in srgb, var(--color-accent) 8%, var(--color-surface));
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, var(--color-line));
    border-radius: 14px;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }
  .ai-cred svg {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: var(--color-accent-ink);
  }

  .modules {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .module {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 1.1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 12px;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.95rem;
  }
  .module svg {
    width: 1.2rem;
    height: 1.2rem;
    color: var(--color-accent-ink);
    flex-shrink: 0;
  }
  .golive-work {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }
  .golive-item {
    display: flex;
    gap: 0.7rem;
    padding: 1.1rem 1.3rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 12px;
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .golive-item svg {
    width: 1.2rem;
    height: 1.2rem;
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: var(--color-accent-ink);
  }

  .problem {
    background: var(--color-surface-2);
  }
  .problem-title {
    margin-top: 0.6rem;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    max-width: 22ch;
  }
  .problem-text {
    margin-top: 1rem;
    color: var(--color-muted);
    font-size: 1.08rem;
    line-height: 1.65;
  }

  .benefits {
    background: var(--color-night);
  }
  .benefits :global(.eyebrow) {
    color: var(--color-accent);
  }
  .benefits :global(.sec-title) {
    color: #fff;
  }
  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .scenarios {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
  }
  .scenario {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 1rem 1.25rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-night-line);
    border-radius: 14px;
    color: #fff;
  }
  .scenario-before {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: line-through;
  }
  .scenario-arrow {
    width: 1.1rem;
    height: 1.1rem;
    color: var(--color-accent);
  }
  .scenario-after {
    font-family: var(--font-display);
    font-weight: 600;
  }

  .tools {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .tool {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.5rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
  }

  .process {
    background: var(--color-surface-2);
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .snap-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
  }
  .snap-title {
    margin-top: 0.5rem;
    font-size: clamp(1.4rem, 3vw, 2rem);
  }
  .snap-text {
    margin-top: 0.5rem;
    color: var(--color-muted);
  }
  .snap-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .related-wrap {
    max-width: 48rem;
  }
  .faq-section {
    background: var(--color-surface-2);
  }
  .faq-wrap {
    max-width: 48rem;
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .benefits-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .work-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .modules {
      grid-template-columns: repeat(3, 1fr);
    }
    .golive-work {
      grid-template-columns: repeat(2, 1fr);
    }
    .snap-card {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
</style>
