---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ServiceCard from "@components/ServiceCard.astro";
import CTASection from "@components/CTASection.astro";
import { Icon } from "astro-icon/components";
import { pillars } from "@data/services";
import { breadcrumbSchema } from "@/lib/schema";

const engagements = [
  {
    icon: "package",
    title: "One-off project",
    text: "A defined build — a site, app, automation or migration — with a fixed scope, timeline and price.",
    best: "Best when you know what you need built.",
    featured: false,
  },
  {
    icon: "repeat",
    title: "Managed retainer",
    text: "Ongoing care and improvement — monitoring, fixes, new features and managed DBA — month to month.",
    best: "Best for live systems that need upkeep.",
    featured: false,
  },
  {
    icon: "compass",
    title: "Consulting",
    text: "Specialist advisory and technical work, including D365 F&O, architecture reviews and incident response.",
    best: "Best when you need expertise, not a full build.",
    featured: true,
  },
];

const guide = [
  { need: "I need to get found and convert visitors", slug: "web-development" },
  { need: "I'm drowning in repetitive work or slow lead follow-up", slug: "ai-automation" },
  { need: "I want an app my customers can use on their phones", slug: "mobile-apps" },
  { need: "My app or reports are slow, or my data feels risky", slug: "database-administration" },
  { need: "My Dynamics 365 ERP needs customizing or integrating", slug: "dynamics-365-finance-operations" },
].map((g) => {
  const p = pillars.find((x) => x.slug === g.slug)!;
  return { ...g, go: p.short, href: p.href, icon: p.icon, accent: p.accent };
});
---

<BaseLayout
  title="Software, automation & data services"
  description="Five connected services — web development, AI automation, mobile apps, database administration and Dynamics 365 — delivered by a Microsoft-certified engineer at affordable prices."
  schemas={[breadcrumbSchema([{ name: "Home", url: "/" }, { name: "Services", url: "/services/" }])]}
>
  <section class="hub-hero">
    <div class="container-x">
      <Breadcrumbs items={[{ name: "Services", url: "/services/" }]} />
      <span class="eyebrow hub-eyebrow" data-reveal>Services</span>
      <h1 class="hub-title" data-reveal>Everything you need to build, automate and run your systems.</h1>
      <p class="hub-sub" data-reveal>
        Five capabilities that work on their own — or combine into one connected business operating
        system. One certified partner, enterprise standards, globally affordable prices.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-x">
      <div class="services-grid">
        {pillars.map((p, i) => (
          <ServiceCard pillar={p} index={i} />
        ))}
      </div>
    </div>
  </section>

  <!-- Which service do I need? -->
  <section class="section guide">
    <div class="container-x">
      <SectionHeading eyebrow="Not sure where to start?" title="Which service do I need?" align="center" />
      <ul class="guide-list">
        {guide.map((g, i) => (
          <li data-reveal data-delay={String((i % 3) + 1)}>
            <a href={g.href} class="guide-item" style={`--pillar:${g.accent}`}>
              <span class="guide-icon"><Icon name={`lucide:${g.icon}`} /></span>
              <span class="guide-need">"{g.need}"</span>
              <span class="guide-go">{g.go} <Icon name="lucide:arrow-right" /></span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Engagement types -->
  <section class="section">
    <div class="container-x">
      <SectionHeading
        eyebrow="Ways to work together"
        title="Pick the engagement that fits."
        text="Whether you need one thing built, an ongoing partner, or specialist advice, there's a model that fits."
      />
      <div class="eng-grid">
        {engagements.map((e, i) => (
          <div
            class:list={["eng-card", "card-hover", e.featured ? "card-gradient" : "card"]}
            data-reveal
            data-delay={String(i + 1)}
          >
            {e.featured && <span class="eng-badge">Most flexible</span>}
            <span class:list={["eng-icon", { feat: e.featured }]}><Icon name={`lucide:${e.icon}`} /></span>
            <h3 class="eng-title">{e.title}</h3>
            <p class="eng-text">{e.text}</p>
            <p class="eng-best">{e.best}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<style>
  .hub-hero {
    position: relative;
    overflow: hidden;
    padding-block: 1.5rem clamp(2rem, 5vw, 3rem);
  }
  .hub-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(45% 60% at 85% 0%, color-mix(in srgb, var(--color-accent) 12%, transparent), transparent 70%);
    pointer-events: none;
  }
  .hub-eyebrow {
    display: block;
    margin-top: 1.5rem;
  }
  .hub-title {
    margin-top: 0.6rem;
    font-size: clamp(2rem, 5vw, 3.25rem);
    max-width: 18ch;
  }
  .hub-sub {
    margin-top: 1.1rem;
    font-size: clamp(1.05rem, 2.2vw, 1.25rem);
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 56ch;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .guide {
    background: var(--color-surface-2);
  }
  .guide-list {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 52rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .guide-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 1.1rem 1.4rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--pillar);
    border-radius: 14px;
    box-shadow: var(--shadow-soft);
    transition: transform 0.2s var(--ease-out), box-shadow 0.2s var(--ease-out);
  }
  .guide-item:hover {
    transform: translateX(5px);
    box-shadow: var(--shadow-lift);
  }
  .guide-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    flex-shrink: 0;
    border-radius: 10px;
    background: color-mix(in srgb, var(--pillar) 14%, transparent);
    color: var(--pillar);
  }
  .guide-icon svg {
    width: 1.3rem;
    height: 1.3rem;
  }
  .guide-need {
    flex: 1;
    min-width: 12rem;
    color: var(--color-ink-soft);
    font-style: italic;
  }
  .guide-go {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-ink);
    white-space: nowrap;
  }
  .guide-go svg {
    width: 1.05rem;
    height: 1.05rem;
    color: var(--pillar);
    transition: transform 0.2s var(--ease-out);
  }
  .guide-item:hover .guide-go svg {
    transform: translateX(4px);
  }

  .eng-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .eng-card {
    position: relative;
    padding: 1.75rem;
  }
  .eng-badge {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.22rem 0.55rem;
    border-radius: var(--radius-pill);
    background: var(--color-accent);
    color: #03222a;
    font-weight: 600;
  }
  .eng-icon {
    display: inline-flex;
    width: 3rem;
    height: 3rem;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent-ink);
    margin-bottom: 1rem;
  }
  .eng-icon.feat {
    background: rgba(255, 255, 255, 0.12);
    color: var(--color-accent);
  }
  .eng-icon svg {
    width: 1.5rem;
    height: 1.5rem;
  }
  .eng-title {
    font-size: 1.2rem;
  }
  .eng-text {
    margin-top: 0.5rem;
    color: var(--color-muted);
    line-height: 1.55;
  }
  .eng-best {
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-accent-ink);
  }
  .card-gradient .eng-text {
    color: rgba(255, 255, 255, 0.8);
  }
  .card-gradient .eng-best {
    color: var(--color-accent);
  }

  @media (min-width: 640px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 980px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .eng-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
